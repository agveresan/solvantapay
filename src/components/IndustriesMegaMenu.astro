---
import type { CollectionEntry } from "astro:content";
import MegaMenuShell from "./MegaMenuShell.astro";
import IndustryIconTile from "./IndustryIconTile.astro";
import { industriesByRisk } from "../lib/industries";

type Props = {
  featured: CollectionEntry<"blog"> | undefined;
  latestArticles: CollectionEntry<"blog">[];
};

const { featured, latestArticles } = Astro.props;

function blogHref(post: CollectionEntry<"blog">) {
  return `/blog/${post.id.replace(/\.md$/, "")}/`;
}

const low = industriesByRisk("low").filter(
  (ind) =>
    ind.slug !== "ecommerce" &&
    ind.slug !== "healthcare" &&
    ind.slug !== "law-firms" &&
    ind.slug !== "medspa" &&
    ind.slug !== "bar-restaurant" &&
    ind.slug !== "retail" &&
    ind.slug !== "home-services" &&
    ind.slug !== "accounting-cpa-firms",
);
const high = industriesByRisk("high").filter(
  (ind) =>
    ind.slug !== "cbd" &&
    ind.slug !== "creator-content" &&
    ind.slug !== "credit-repair" &&
    ind.slug !== "ai" &&
    ind.slug !== "firearms" &&
    ind.slug !== "fantasy-sports" &&
    ind.slug !== "travel" &&
    ind.slug !== "vape" &&
    ind.slug !== "telemedicine" &&
    ind.slug !== "online-dating" &&
    ind.slug !== "saas",
);
let iconIndex = 0;
---
<MegaMenuShell>
  <div slot="main">
    <div class="mega-menu__tier">
      <p class="mega-menu__tier-title">Low-risk</p>
      <div class="mega-menu__grid">
        <a class="mega-menu__link" href="/ecommerce-payment-processing/">
          <IndustryIconTile variant={iconIndex++} />
          <span class="mega-menu__link-text">Ecommerce</span>
        </a>
        <a class="mega-menu__link" href="/healthcare-payment-processing/">
          <IndustryIconTile variant={iconIndex++} />
          <span class="mega-menu__link-text">Healthcare</span>
        </a>
        <a class="mega-menu__link" href="/law-firm-payment-processing/">
          <IndustryIconTile variant={iconIndex++} />
          <span class="mega-menu__link-text">Law firms</span>
        </a>
        <a class="mega-menu__link" href="/med-spa-payment-processing/">
          <IndustryIconTile variant={iconIndex++} />
          <span class="mega-menu__link-text">Med spa</span>
        </a>
        <a class="mega-menu__link" href="/bar-restaurant-payment-processing/">
          <IndustryIconTile variant={iconIndex++} />
          <span class="mega-menu__link-text">Bar & restaurant</span>
        </a>
        <a class="mega-menu__link" href="/retail-payment-processing/">
          <IndustryIconTile variant={iconIndex++} />
          <span class="mega-menu__link-text">Retail</span>
        </a>
        <a class="mega-menu__link" href="/home-services-payment-processing/">
          <IndustryIconTile variant={iconIndex++} />
          <span class="mega-menu__link-text">Home services</span>
        </a>
        <a class="mega-menu__link" href="/accounting-cpa-firm-payment-processing/">
          <IndustryIconTile variant={iconIndex++} />
          <span class="mega-menu__link-text">Accounting &amp; CPA</span>
        </a>
        {low.map((ind) => {
          const idx = iconIndex++;
          return (
            <a class="mega-menu__link" href={`/industries/${ind.slug}/`}>
              <IndustryIconTile variant={idx} />
              <span class="mega-menu__link-text">{ind.title}</span>
            </a>
          );
        })}
      </div>
    </div>
    <div class="mega-menu__tier">
      <p class="mega-menu__tier-title">High-risk</p>
      <div class="mega-menu__grid">
        <a class="mega-menu__link" href="/peptide-payment-processing/">
          <IndustryIconTile variant={iconIndex++} />
          <span class="mega-menu__link-text">Peptides</span>
        </a>
        <a class="mega-menu__link" href="/cbd-payment-processing/">
          <IndustryIconTile variant={iconIndex++} />
          <span class="mega-menu__link-text">CBD</span>
        </a>
        <a class="mega-menu__link" href="/content-creator-payment-processing/">
          <IndustryIconTile variant={iconIndex++} />
          <span class="mega-menu__link-text">Creators</span>
        </a>
        <a class="mega-menu__link" href="/credit-repair-payment-processing/">
          <IndustryIconTile variant={iconIndex++} />
          <span class="mega-menu__link-text">Credit repair</span>
        </a>
        <a class="mega-menu__link" href="/adult-content-payment-processing/">
          <IndustryIconTile variant={iconIndex++} />
          <span class="mega-menu__link-text">Adult content</span>
        </a>
        <a class="mega-menu__link" href="/ai-payment-processing/">
          <IndustryIconTile variant={iconIndex++} />
          <span class="mega-menu__link-text">AI</span>
        </a>
        <a class="mega-menu__link" href="/saas-payment-processing/">
          <IndustryIconTile variant={iconIndex++} />
          <span class="mega-menu__link-text">SaaS</span>
        </a>
        <a class="mega-menu__link" href="/firearms-payment-processing/">
          <IndustryIconTile variant={iconIndex++} />
          <span class="mega-menu__link-text">Firearms</span>
        </a>
        <a class="mega-menu__link" href="/nutraceuticals-payment-processing/">
          <IndustryIconTile variant={iconIndex++} />
          <span class="mega-menu__link-text">Nutraceuticals</span>
        </a>
        <a class="mega-menu__link" href="/fantasy-sports-payment-processing/">
          <IndustryIconTile variant={iconIndex++} />
          <span class="mega-menu__link-text">Fantasy sports</span>
        </a>
        <a class="mega-menu__link" href="/travel-payment-processing/">
          <IndustryIconTile variant={iconIndex++} />
          <span class="mega-menu__link-text">Travel</span>
        </a>
        <a class="mega-menu__link" href="/vape-payment-processing/">
          <IndustryIconTile variant={iconIndex++} />
          <span class="mega-menu__link-text">Vape</span>
        </a>
        <a class="mega-menu__link" href="/telemedicine-payment-processing/">
          <IndustryIconTile variant={iconIndex++} />
          <span class="mega-menu__link-text">Telemedicine</span>
        </a>
        <a class="mega-menu__link" href="/online-dating-payment-processing/">
          <IndustryIconTile variant={iconIndex++} />
          <span class="mega-menu__link-text">Online dating</span>
        </a>
        {high.map((ind) => {
          const idx = iconIndex++;
          return (
            <a class="mega-menu__link" href={`/industries/${ind.slug}/`}>
              <IndustryIconTile variant={idx} />
              <span class="mega-menu__link-text">{ind.title}</span>
            </a>
          );
        })}
      </div>
    </div>
    <a class="mega-menu__footer-link" href="/industries/">View all →</a>
  </div>
  <div slot="sidebar">
    {
      featured && (
        <a class="mega-menu__featured" href={blogHref(featured)}>
          <p class="mega-menu__featured-eyebrow">Featured</p>
          <p class="mega-menu__featured-title">{featured.data.title}</p>
        </a>
      )
    }
    <p class="mega-menu__articles-head">Latest articles</p>
    {
      latestArticles.length === 0 ? (
        <p class="muted" style="margin: 0; font-size: 0.88rem;">
          Articles coming soon.
        </p>
      ) : (
        latestArticles.map((post) => (
          <a class="mega-menu__article-link" href={blogHref(post)}>
            {post.data.title}
          </a>
        ))
      )
    }
  </div>
</MegaMenuShell>
