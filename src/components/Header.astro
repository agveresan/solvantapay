---
import { getCollection } from "astro:content";
import IndustriesMegaMenu from "./IndustriesMegaMenu.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featured = posts[0];
const latestArticles = posts.slice(1, 3);
---
<div class="site-header-shell">
  <header class="site-header">
    <div class="container site-header__inner">
      <a class="logo" href="/">
        <span class="logo__mark" aria-hidden="true">SP</span>
        <span>Solvanta Pay</span>
      </a>
      <nav class="nav" aria-label="Primary">
        <a href="/solutions/">Solutions</a>
        <div class="nav-dropdown">
          <button
            type="button"
            class="nav-dropdown__trigger"
            id="nav-industries-trigger"
            aria-expanded="false"
            aria-controls="mega-industries"
            aria-haspopup="true"
          >
            Industries
            <span class="nav-dropdown__chevron" aria-hidden="true"></span>
          </button>
        </div>
        <a href="/about/">About</a>
        <a href="/blog/">Insights</a>
        <a class="btn btn--primary" href="/apply/">Apply</a>
      </nav>
    </div>
  </header>
  <div
    id="mega-industries"
    class="mega-menu"
    role="region"
    aria-label="Industries menu"
    hidden
  >
    <IndustriesMegaMenu featured={featured} latestArticles={latestArticles} />
  </div>
</div>
<script is:inline>
  (function () {
    const btn = document.getElementById("nav-industries-trigger");
    const panel = document.getElementById("mega-industries");
    if (!btn || !panel) return;

    var openTimer = 0;
    var closeTimer = 0;
    var HOVER_OPEN_MS = 140;
    var HOVER_CLOSE_MS = 220;
    var hoverMenu =
      typeof window.matchMedia === "function" &&
      window.matchMedia("(hover: hover) and (pointer: fine)").matches;

    function clearTimers() {
      if (openTimer) clearTimeout(openTimer);
      if (closeTimer) clearTimeout(closeTimer);
      openTimer = 0;
      closeTimer = 0;
    }

    function close() {
      clearTimers();
      panel.hidden = true;
      btn.setAttribute("aria-expanded", "false");
    }

    function open() {
      clearTimers();
      panel.hidden = false;
      btn.setAttribute("aria-expanded", "true");
    }

    function toggle() {
      if (panel.hidden) open();
      else close();
    }

    function scheduleOpen() {
      clearTimeout(closeTimer);
      closeTimer = 0;
      clearTimeout(openTimer);
      openTimer = setTimeout(function () {
        openTimer = 0;
        open();
      }, HOVER_OPEN_MS);
    }

    function scheduleClose() {
      clearTimeout(openTimer);
      openTimer = 0;
      clearTimeout(closeTimer);
      closeTimer = setTimeout(function () {
        closeTimer = 0;
        close();
      }, HOVER_CLOSE_MS);
    }

    function cancelScheduledClose() {
      clearTimeout(closeTimer);
      closeTimer = 0;
    }

    btn.addEventListener("click", function (e) {
      e.stopPropagation();
      toggle();
    });

    if (hoverMenu) {
      btn.addEventListener("mouseenter", scheduleOpen);
      btn.addEventListener("mouseleave", scheduleClose);
      panel.addEventListener("mouseenter", function () {
        clearTimeout(openTimer);
        openTimer = 0;
        cancelScheduledClose();
        open();
      });
      panel.addEventListener("mouseleave", scheduleClose);
    }

    document.addEventListener("click", function (e) {
      var t = e.target;
      if (!t || !panel || panel.hidden) return;
      if (t instanceof Node && !panel.contains(t) && !btn.contains(t)) close();
    });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && !panel.hidden) close();
    });
  })();
</script>
