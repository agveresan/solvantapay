---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container footer__grid">
    <div>
      <strong style="font-family: var(--font-head); color: var(--color-primary);">Solvanta Pay</strong>
      <p class="muted" style="margin-top: 0.5rem; max-width: 36ch;">
        Payment processing for high-risk merchants — underwriting-minded, compliance-aware, built for reliability.
      </p>
    </div>
    <div>
      <div class="eyebrow">Explore</div>
      <ul style="list-style: none; padding: 0; margin: 0.5rem 0 0;">
        <li><a href="/solutions/">Solutions</a></li>
        <li><a href="/industries/">Industries</a></li>
        <li><a href="/blog/">Insights</a></li>
      </ul>
    </div>
    <div>
      <div class="eyebrow">Legal</div>
      <ul style="list-style: none; padding: 0; margin: 0.5rem 0 0;">
        <li><a href="/privacy/">Privacy</a></li>
        <li><a href="/terms/">Terms</a></li>
      </ul>
    </div>
  </div>
  <div class="container" style="margin-top: 2rem;">
    <p class="muted" style="font-size: 0.9rem; margin: 0;">
      &copy; {year} Solvanta Pay. Indicative quotes are not binding offers.
    </p>
  </div>
</footer>
