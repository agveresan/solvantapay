---
import { Picture } from "astro:assets";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import heroVisual from "../../../assets/images/hero-placeholder.png";
import { getSiteUrl } from "../../../lib/site";
import { applyIndustryQueryValue } from "../../../lib/industries";
import type { Industry } from "../../../lib/industries";
import type { CollectionEntry } from "astro:content";

type Props = {
  industry: Industry;
  relatedPosts?: CollectionEntry<"blog">[];
};
const { industry, relatedPosts = [] } = Astro.props;

const site = getSiteUrl();
const salesTel = "+18556002419";
const canonical = new URL(`/industries/${industry.slug}/`, site).href;
const applyHref = `/apply/?industry=${applyIndustryQueryValue(industry.title)}`;

const pageTitle = "Firearms payment processing | Solvanta Pay";
const pageDescription =
  "FFL payment processing and firearms merchant accounts for dealers and retailers. Compliant firearms payment gateways, ammo and accessories, stable high-risk placement — payment processing for gun stores.";

const webPageLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonical,
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
    { "@type": "ListItem", position: 2, name: "Industries", item: `${site}/industries/` },
    {
      "@type": "ListItem",
      position: 3,
      name: industry.title,
      item: canonical,
    },
  ],
};

const faqCopy = [
  {
    q: "Can firearms businesses get approved for payment processing?",
    a: "Yes. Many mainstream providers restrict firearms, but we work with banks that support compliant firearms businesses — subject to underwriting, licensing verification, and bank partner appetite.",
  },
  {
    q: "Do you work with FFL dealers?",
    a: "Yes. We support federally licensed firearms dealers and related businesses when documentation and underwriting align.",
  },
  {
    q: "Can I process payments online for firearms?",
    a: "What is available depends on product mix, jurisdiction, and processor rules. We help you understand options and structure applications around compliant models — final placement is determined in underwriting.",
  },
  {
    q: "What if I've been declined before?",
    a: "That is common. Many firearms businesses come to us after being rejected by traditional processors. We map your FFL and operations to the right underwriting path when documentation supports it.",
  },
  {
    q: "How long does approval take?",
    a: "Many businesses see a decision within 24–72 hours when applications and documents are complete. Timing depends on underwriting and bank response times.",
  },
] as const;

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqCopy.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---
<BaseLayout title={pageTitle} description={pageDescription} jsonLd={[webPageLd, breadcrumbLd, faqLd]}>
  <section class="hero">
    <div class="container hero__grid">
      <div>
        <span class="pill">FFL dealers & firearms retail</span>
        <p class="eyebrow" style="margin: 0.75rem 0 0; font-size: 0.78rem;">
          Built for compliant firearms businesses
        </p>
        <h1 style="font-size: clamp(2rem, 4vw, 2.85rem); margin: 0.5rem 0 1rem;">
          Firearms payment processing that keeps you approved
        </h1>
        <p class="muted" style="font-size: 1.1rem; max-width: 52ch;">
          Selling firearms, ammo, or accessories? We provide compliant, high-risk-friendly merchant accounts built for FFL
          dealers and firearms businesses — clear underwriting, no hype.
        </p>
        <p class="muted" style="font-size: 0.95rem; max-width: 52ch; margin-top: 0.65rem;">
          Works with FFL dealers and licensed retailers — we understand licensing, policy, and stability.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem;">
          <a class="btn btn--primary" href={applyHref}>Get approved for firearms processing</a>
          <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
        </div>
        <ul class="trust-row trust-row--four" aria-label="Trust highlights">
          <li>Built for firearms and FFL dealers</li>
          <li>Compliance-focused processing solutions</li>
          <li>Stable, long-term merchant accounts</li>
          <li>Fast approvals — often 24–72 hours when docs are complete</li>
        </ul>
      </div>
      <div class="hero__aside">
        <Picture
          src={heroVisual}
          alt="Abstract brand visual suggesting structured payment operations"
          widths={[400, 800, 1200]}
          sizes="(min-width: 900px) min(40vw, 540px), 100vw"
          formats={["avif", "webp"]}
          fallbackFormat="jpeg"
          quality={80}
          loading="eager"
          decoding="async"
          class="hero__visual"
        />
        <div class="card card--glass">
          <div class="eyebrow">At a glance</div>
          <ul style="margin: 1rem 0 0; padding-left: 1.1rem;">
            <li>Conversations aligned with FFL and processor expectations</li>
            <li>E-commerce and in-person placement where underwriting allows</li>
            <li>Chargeback monitoring and reserve clarity in plain language</li>
          </ul>
          <p class="muted" style="margin-top: 1rem; font-size: 0.95rem;">
            Content on this site is informational and not legal advice. Underwriting determines final approval and
            pricing.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why firearms businesses struggle to process payments</h2>
      <p class="muted" style="max-width: 62ch;">
        Even fully legal firearms businesses face major challenges with payment processing because of strict bank
        policies and risk classifications.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Restricted by most processors</h3>
          <p class="muted">
            Many providers like Stripe, PayPal, and Square prohibit or heavily restrict firearms-related businesses.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Complex compliance requirements</h3>
          <p class="muted">
            FFL verification, product restrictions, and transaction rules make underwriting more difficult.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Account shutdowns and policy changes</h3>
          <p class="muted">
            Even approved businesses may be terminated if policies change or risk thresholds shift.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Limited payment options</h3>
          <p class="muted">
            Firearms merchants often have fewer reliable processing solutions available.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Scaling challenges</h3>
          <p class="muted">
            As your business grows, processors may impose limits, reserves, or additional scrutiny.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built specifically for firearms and FFL businesses</h2>
      <p class="muted" style="max-width: 62ch;">
        We understand the regulatory landscape of firearms — and we build processing solutions that align with it.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Firearms-friendly merchant account approval</h3>
          <p class="muted">
            We work with banks and processors that support firearms, ammo, and accessories — when underwriting aligns.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Compliance-focused setup</h3>
          <p class="muted">
            We help you align with FFL requirements and processor guidelines so underwriting sees a coherent story.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Stable, long-term processing</h3>
          <p class="muted">
            Solutions aimed at avoiding sudden shutdowns and policy-related disruptions where possible.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">E-commerce and in-store support</h3>
          <p class="muted">
            Process payments online, in-store, or both — depending on your setup and bank appetite.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Chargeback monitoring and protection</h3>
          <p class="muted">
            Reduce disputes and protect your merchant account with monitoring and clear policies.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Scalable infrastructure</h3>
          <p class="muted">
            Grow your firearms business with processing stability — not surprise holds after every spike.
          </p>
        </div>
      </div>
      <p style="margin-top: 1.5rem;">
        <a class="btn btn--primary" href={applyHref}>Start your application</a>
      </p>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built for firearms businesses like yours</h2>
      <p class="muted" style="max-width: 62ch;">We work with:</p>
      <ul style="margin: 1rem 0 0; padding-left: 1.25rem; max-width: 62ch;">
        <li>FFL dealers</li>
        <li>Firearms retailers</li>
        <li>Ammunition sellers</li>
        <li>Accessories and parts businesses</li>
        <li>Online firearms marketplaces</li>
        <li>Tactical gear companies</li>
      </ul>
      <p class="muted" style="margin-top: 1rem; max-width: 62ch;">
        Whether you run an e-commerce store, a physical location, or a hybrid — we can support your setup when
        underwriting and compliance align.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Get approved in three simple steps</h2>
      <p class="muted" style="max-width: 62ch;">
        Straightforward application — firearms-aware underwriting — then go live.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">1</span>
          <h3 style="margin-top: 0;">Apply online</h3>
          <p class="muted">
            Tell us about your firearms business, products, and monthly volume.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">2</span>
          <h3 style="margin-top: 0;">Underwriting review</h3>
          <p class="muted">
            We match you with firearms-friendly bank and gateway options based on your risk profile.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">3</span>
          <h3 style="margin-top: 0;">Get approved and start processing</h3>
          <p class="muted">
            Launch with a stable merchant account built for your business — with clear monitoring expectations.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Trusted by firearms retailers nationwide</h2>
      <p class="muted" style="max-width: 62ch;">
        Replace with real testimonials when available — this vertical values trust and stability.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">
            “Finally found a processor that understands our industry.”
          </p>
        </blockquote>
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">
            “Reliable payments without worrying about shutdowns.”
          </p>
        </blockquote>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Everything you need to process firearms payments</h2>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Firearms-compliant payment gateways</h3>
          <p class="muted">Gateway placement aligned with how you sell.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">E-commerce and POS integration</h3>
          <p class="muted">Online and in-store flows where partners support them.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Fraud and chargeback monitoring</h3>
          <p class="muted">Visibility before disputes become a profile problem.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">High-volume scaling capability</h3>
          <p class="muted">Plan for growth with underwriting instead of surprise limits.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Secure payment processing</h3>
          <p class="muted">Stable checkout experiences for regulated product sales.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Domestic processing solutions</h3>
          <p class="muted">Placement focused on compliant U.S. operations when that fits your model.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why firearms businesses choose Solvanta Pay</h2>
      <div class="grid-2" style="margin-top: 1.5rem;">
        <div class="card">
          <h3 style="margin-top: 0;">High-risk industry focus</h3>
          <p class="muted">We specialize in verticals mass-market processors avoid.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Firearms compliance and underwriting</h3>
          <p class="muted">We understand FFL expectations and what issuers ask in review.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Bank relationships others do not have</h3>
          <p class="muted">Partnerships for restricted categories.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Stable, long-term systems</h3>
          <p class="muted">Processing built for continuity — not a disposable MID.</p>
        </div>
      </div>
      <div class="card" style="margin-top: 1.5rem;">
        <p class="muted" style="margin: 0; font-size: 1.05rem;">
          Most processors avoid firearms. We are built for it.
        </p>
      </div>
    </div>
  </section>

  <div class="hub-cta-strip">
    <div class="hub-cta-strip__inner">
      <div>
        <h2 class="hub-cta-strip__title">Stop getting restricted. Start processing today.</h2>
        <p class="muted" style="margin: 0; max-width: 48ch;">
          Get a firearms-friendly merchant account designed for compliance, stability, and growth. Apply now or call —
          we speak high-risk fluently.
        </p>
      </div>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center;">
        <a class="btn btn--primary" href={applyHref}>Apply now</a>
        <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
      </div>
    </div>
  </div>

  <section class="section section--tight">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Firearms payment processing FAQ</h2>
      <div class="grid-2" style="margin-top: 1.25rem;">
        {faqCopy.map((item) => (
          <div class="card">
            <h3 style="font-size: 1.1rem; margin-top: 0;">{item.q}</h3>
            <p class="muted" style="margin-bottom: 0;">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  {
    relatedPosts.length > 0 && (
      <section class="section section--tight">
        <div class="container">
          <h2 style="margin-bottom: 1rem;">Related reading</h2>
          <ul style="list-style: none; padding: 0; margin: 0; display: grid; gap: 0.75rem;">
            {relatedPosts.map((post) => (
              <li>
                <a
                  href={`/blog/${post.id.replace(/\.md$/, "")}/`}
                  style="font-weight: 600; text-decoration: none;"
                >
                  {post.data.title}
                </a>
                <p class="muted" style="margin: 0.25rem 0 0; font-size: 0.95rem;">
                  {post.data.description}
                </p>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }
</BaseLayout>
