---
import { Picture } from "astro:assets";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import heroVisual from "../../../assets/images/hero-placeholder.png";
import { getSiteUrl } from "../../../lib/site";
import { applyIndustryQueryValue } from "../../../lib/industries";
import type { Industry } from "../../../lib/industries";
import type { CollectionEntry } from "astro:content";

type Props = {
  industry: Industry;
  relatedPosts?: CollectionEntry<"blog">[];
};
const { industry, relatedPosts = [] } = Astro.props;

const site = getSiteUrl();
const salesTel = "+18556002419";
const canonical = new URL(`/industries/${industry.slug}/`, site).href;
const applyHref = `/apply/?industry=${applyIndustryQueryValue(industry.title)}`;

const pageTitle = "Nutraceutical payment processing | Solvanta Pay";
const pageDescription =
  "Nutraceutical merchant accounts and supplement payment processing for wellness brands. High-risk supplement processing, continuity billing, autoship — nutraceutical payment gateway for e-commerce.";

const webPageLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonical,
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
    { "@type": "ListItem", position: 2, name: "Industries", item: `${site}/industries/` },
    {
      "@type": "ListItem",
      position: 3,
      name: industry.title,
      item: canonical,
    },
  ],
};

const faqCopy = [
  {
    q: "Can supplement businesses get approved for payment processing?",
    a: "Yes. Supplements are high-risk, but we work with banks that specialize in nutraceuticals and supplements — subject to underwriting, documentation, and bank partner appetite.",
  },
  {
    q: "Do you support continuity and subscription billing?",
    a: "Yes. Autoship and recurring billing models are supported — with clear billing descriptors, cancellation paths, and dispute expectations.",
  },
  {
    q: "What if I've been shut down before?",
    a: "That is very common. Many of our clients come to us after being dropped by traditional processors. We map your offer and fulfillment story to the right underwriting path.",
  },
  {
    q: "Do you work with high-volume brands?",
    a: "Yes. We work with supplement businesses processing significant monthly volume — capacity and reserves depend on underwriting and risk review.",
  },
  {
    q: "How long does approval take?",
    a: "Many businesses see a decision within 24–72 hours when applications and documents are complete. Timing depends on underwriting and bank response times.",
  },
] as const;

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqCopy.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---
<BaseLayout title={pageTitle} description={pageDescription} jsonLd={[webPageLd, breadcrumbLd, faqLd]}>
  <section class="hero">
    <div class="container hero__grid">
      <div>
        <span class="pill">Supplements & wellness e-commerce</span>
        <h1 style="font-size: clamp(2rem, 4vw, 2.85rem); margin: 1rem 0;">
          Nutraceutical payment processing that actually scales
        </h1>
        <p class="muted" style="font-size: 1.1rem; max-width: 52ch;">
          Selling supplements, wellness products, or nutraceuticals? We provide stable, high-risk-friendly merchant
          accounts built for supplement brands and e-commerce businesses.
        </p>
        <p class="muted" style="font-size: 0.95rem; max-width: 52ch; margin-top: 0.75rem; font-weight: 600;">
          Running autoship or free trial offers? We are built for it.
        </p>
        <p class="muted" style="font-size: 0.95rem; max-width: 52ch; margin-top: 0.35rem; font-weight: 600;">
          Processing $50K–$1M+/month? We can support your growth — subject to underwriting.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem;">
          <a class="btn btn--primary" href={applyHref}>Get approved for nutraceutical processing</a>
          <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
        </div>
        <ul class="trust-row trust-row--four" aria-label="Trust highlights">
          <li>Built for nutraceutical and supplement brands</li>
          <li>Continuity and subscription-friendly billing</li>
          <li>High-volume scaling support</li>
          <li>Fast approvals — often 24–72 hours when docs are complete</li>
        </ul>
      </div>
      <div class="hero__aside">
        <Picture
          src={heroVisual}
          alt="Abstract brand visual suggesting structured payment operations"
          widths={[400, 800, 1200]}
          sizes="(min-width: 900px) min(40vw, 540px), 100vw"
          formats={["avif", "webp"]}
          fallbackFormat="jpeg"
          quality={80}
          loading="eager"
          decoding="async"
          class="hero__visual"
        />
        <div class="card card--glass">
          <div class="eyebrow">At a glance</div>
          <ul style="margin: 1rem 0 0; padding-left: 1.1rem;">
            <li>Underwriting that understands continuity, trials, and supplement economics</li>
            <li>Chargeback-aware monitoring for aggressive growth brands</li>
            <li>Multi-MID and backup strategies where underwriting allows</li>
          </ul>
          <p class="muted" style="margin-top: 1rem; font-size: 0.95rem;">
            Content on this site is informational and not legal advice. Underwriting determines final approval and
            pricing.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why nutraceutical businesses struggle to process payments</h2>
      <p class="muted" style="max-width: 62ch;">
        The supplement industry is one of the most heavily scrutinized in payment processing — especially for
        fast-growing brands.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">High-risk classification</h3>
          <p class="muted">
            Supplements and nutraceuticals are often flagged due to claims, fulfillment issues, and regulatory concerns.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Account shutdowns without warning</h3>
          <p class="muted">
            Many businesses get approved initially — only to be shut down once volume increases.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">High chargeback rates</h3>
          <p class="muted">
            Free trials, continuity offers, and aggressive marketing can lead to disputes.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Compliance and claim restrictions</h3>
          <p class="muted">
            Health claims, landing pages, and ad messaging can trigger processor concerns.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Cash flow disruptions</h3>
          <p class="muted">
            Rolling reserves, payout delays, and holds can impact your ability to scale.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built specifically for nutraceutical and supplement brands</h2>
      <p class="muted" style="max-width: 62ch;">
        We understand the nuances of supplement businesses — and we build processing systems that support growth without
        unnecessary interruption.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">High-risk merchant account approval</h3>
          <p class="muted">
            We work with banks experienced in nutraceuticals, supplements, and wellness products.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Continuity and subscription billing support</h3>
          <p class="muted">
            Built for autoship programs, memberships, and recurring revenue models.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Stable, long-term processing</h3>
          <p class="muted">
            Accounts structured for scalability — not random shutdowns when sales spike.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Compliance-aware structuring</h3>
          <p class="muted">
            We help position your business clearly for underwriting — claims, fulfillment, and billing in one story.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Chargeback mitigation tools</h3>
          <p class="muted">
            Monitoring, alerts, and prevention strategies so disputes do not define your profile overnight.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Multi-MID and backup processing</h3>
          <p class="muted">
            Layered infrastructure as you grow — where underwriting allows.
          </p>
        </div>
      </div>
      <p style="margin-top: 1.5rem;">
        <a class="btn btn--primary" href={applyHref}>Start your application</a>
      </p>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built for supplement brands like yours</h2>
      <p class="muted" style="max-width: 62ch;">We work with:</p>
      <ul style="margin: 1rem 0 0; padding-left: 1.25rem; max-width: 62ch;">
        <li>Nutraceutical brands</li>
        <li>Dietary supplement companies</li>
        <li>Vitamin and wellness products</li>
        <li>Weight loss and fitness supplements</li>
        <li>Nootropics and performance products</li>
        <li>Continuity and autoship programs</li>
        <li>High-volume e-commerce supplement stores</li>
      </ul>
      <p class="muted" style="margin-top: 1rem; max-width: 62ch;">
        Whether you run Shopify, funnels, or a custom checkout — we integrate with common stacks so operations stay yours
        while we align the merchant account.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Get approved in three simple steps</h2>
      <p class="muted" style="max-width: 62ch;">
        One application — supplement-aware underwriting — then launch.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">1</span>
          <h3 style="margin-top: 0;">Apply online</h3>
          <p class="muted">
            Tell us about your products, billing model, and monthly volume.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">2</span>
          <h3 style="margin-top: 0;">Underwriting review</h3>
          <p class="muted">
            We match you with bank appetite for your business model and risk profile.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">3</span>
          <h3 style="margin-top: 0;">Get approved and start processing</h3>
          <p class="muted">
            Launch with a stable merchant account built for your brand — with clear monitoring and reserve expectations.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Trusted by high-growth supplement brands</h2>
      <p class="muted" style="max-width: 62ch;">
        Replace with real testimonials for stronger conversion — continuity and scale stories perform well here.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">
            “We scaled our supplement brand without worrying about shutdowns.”
          </p>
        </blockquote>
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">
            “Finally found a processor that understands continuity offers.”
          </p>
        </blockquote>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Everything you need to process nutraceutical payments</h2>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Subscription and continuity billing support</h3>
          <p class="muted">Autoship and renewals with clear policies.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">E-commerce and funnel integrations</h3>
          <p class="muted">Connect the stacks you already use where partners allow.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Fraud and chargeback monitoring</h3>
          <p class="muted">Visibility before disputes become a profile problem.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">High-volume scaling capability</h3>
          <p class="muted">Plan for growth with underwriting instead of surprise holds.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">International payment support</h3>
          <p class="muted">Cross-border selling where your entity and bank stack support it.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Secure payment gateways</h3>
          <p class="muted">Checkout flows aligned with how supplements are sold online.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why nutraceutical brands choose Solvanta Pay</h2>
      <div class="grid-2" style="margin-top: 1.5rem;">
        <div class="card">
          <h3 style="margin-top: 0;">High-risk e-commerce and supplements</h3>
          <p class="muted">We specialize in categories that outgrow generic processors.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Claims, compliance, and underwriting</h3>
          <p class="muted">We understand what issuers ask about in supplement verticals.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Bank relationships others do not have</h3>
          <p class="muted">Partnerships for restricted and high-growth CPG-style brands.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Scalable, long-term systems</h3>
          <p class="muted">Processing built to scale with ad spend and volume — not cap you overnight.</p>
        </div>
      </div>
      <div class="card" style="margin-top: 1.5rem;">
        <p class="muted" style="margin: 0; font-size: 1.05rem;">
          Most processors cannot handle supplement brands at scale. We are built for it.
        </p>
      </div>
    </div>
  </section>

  <div class="hub-cta-strip">
    <div class="hub-cta-strip__inner">
      <div>
        <h2 class="hub-cta-strip__title">Stop getting shut down. Start scaling your brand.</h2>
        <p class="muted" style="margin: 0; max-width: 48ch;">
          Get a nutraceutical-friendly merchant account designed for stability, compliance, and growth. Apply now or
          call — we speak high-risk fluently.
        </p>
      </div>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center;">
        <a class="btn btn--primary" href={applyHref}>Apply now</a>
        <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
      </div>
    </div>
  </div>

  <section class="section section--tight">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Nutraceutical payment processing FAQ</h2>
      <div class="grid-2" style="margin-top: 1.25rem;">
        {faqCopy.map((item) => (
          <div class="card">
            <h3 style="font-size: 1.1rem; margin-top: 0;">{item.q}</h3>
            <p class="muted" style="margin-bottom: 0;">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  {
    relatedPosts.length > 0 && (
      <section class="section section--tight">
        <div class="container">
          <h2 style="margin-bottom: 1rem;">Related reading</h2>
          <ul style="list-style: none; padding: 0; margin: 0; display: grid; gap: 0.75rem;">
            {relatedPosts.map((post) => (
              <li>
                <a
                  href={`/blog/${post.id.replace(/\.md$/, "")}/`}
                  style="font-weight: 600; text-decoration: none;"
                >
                  {post.data.title}
                </a>
                <p class="muted" style="margin: 0.25rem 0 0; font-size: 0.95rem;">
                  {post.data.description}
                </p>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }
</BaseLayout>
