---
import { Picture } from "astro:assets";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import heroVisual from "../../../assets/images/hero-placeholder.png";
import { getSiteUrl } from "../../../lib/site";
import { applyIndustryQueryValue } from "../../../lib/industries";
import type { Industry } from "../../../lib/industries";
import type { CollectionEntry } from "astro:content";

type Props = {
  industry: Industry;
  relatedPosts?: CollectionEntry<"blog">[];
};
const { industry, relatedPosts = [] } = Astro.props;

const site = getSiteUrl();
const salesTel = "+18556002419";
const canonical = new URL(`/industries/${industry.slug}/`, site).href;
const applyHref = `/apply/?industry=${applyIndustryQueryValue(industry.title)}`;

const pageTitle = "AI payment processing | Solvanta Pay";
const pageDescription =
  "AI merchant accounts and SaaS payment processing for AI platforms and tools. Subscription and usage-based billing, high-risk AI placement, API-friendly gateways — payment processing for AI SaaS.";

const webPageLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonical,
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
    { "@type": "ListItem", position: 2, name: "Industries", item: `${site}/industries/` },
    {
      "@type": "ListItem",
      position: 3,
      name: industry.title,
      item: canonical,
    },
  ],
};

const faqCopy = [
  {
    q: "Can AI businesses get approved for payment processing?",
    a: "Yes. Even when your platform sits in a gray area for issuers, we work with banks that understand emerging technology models — subject to underwriting, documentation, and bank partner appetite.",
  },
  {
    q: "Do you support SaaS and subscription billing?",
    a: "Yes. We support recurring billing, subscriptions, and usage-based pricing models — with clear descriptors and cancellation paths that match how you bill.",
  },
  {
    q: "What if my platform has been flagged or shut down before?",
    a: "That is common. Many AI businesses come to us after being dropped by traditional processors. We map your model to the right underwriting conversation when documentation supports it.",
  },
  {
    q: "Do you support international customers?",
    a: "Yes. We can discuss solutions for global user bases and international payments where your entity structure and bank stack support them.",
  },
  {
    q: "How long does approval take?",
    a: "Many AI businesses see a decision within 24–72 hours when applications and documents are complete. Timing depends on underwriting and bank response times.",
  },
] as const;

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqCopy.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---
<BaseLayout title={pageTitle} description={pageDescription} jsonLd={[webPageLd, breadcrumbLd, faqLd]}>
  <section class="hero">
    <div class="container hero__grid">
      <div>
        <span class="pill">AI, SaaS & platforms</span>
        <h1 style="font-size: clamp(2rem, 4vw, 2.85rem); margin: 1rem 0;">
          AI payment processing that scales with your platform
        </h1>
        <p class="muted" style="font-size: 1.1rem; max-width: 52ch;">
          Building an AI product or SaaS? We provide stable, high-risk-friendly payment processing for AI platforms,
          tools, and subscription-based businesses.
        </p>
        <p class="muted" style="font-size: 0.98rem; max-width: 52ch; margin-top: 0.75rem; font-weight: 600;">
          Building fast? Don’t let your payment processor slow you down.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem;">
          <a class="btn btn--primary" href={applyHref}>Get approved for AI processing</a>
          <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
        </div>
        <ul class="trust-row trust-row--four" aria-label="Trust highlights">
          <li>Built for AI SaaS and digital platforms</li>
          <li>Subscription and usage-based billing support</li>
          <li>High-risk and gray-area AI models welcome</li>
          <li>Fast approvals — often 24–72 hours when docs are complete</li>
        </ul>
      </div>
      <div class="hero__aside">
        <Picture
          src={heroVisual}
          alt="Abstract brand visual suggesting structured payment operations"
          widths={[400, 800, 1200]}
          sizes="(min-width: 900px) min(40vw, 540px), 100vw"
          formats={["avif", "webp"]}
          fallbackFormat="jpeg"
          quality={80}
          loading="eager"
          decoding="async"
          class="hero__visual"
        />
        <div class="card card--glass">
          <div class="eyebrow">At a glance</div>
          <ul style="margin: 1rem 0 0; padding-left: 1.1rem;">
            <li>Underwriting that understands SaaS, APIs, and usage billing</li>
            <li>Support for recurring revenue and dispute-aware operations</li>
            <li>Multi-MID and backup strategies where underwriting allows</li>
          </ul>
          <p class="muted" style="margin-top: 1rem; font-size: 0.95rem;">
            Content on this site is informational and not legal advice. Underwriting determines final approval and
            pricing.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why AI businesses struggle to process payments</h2>
      <p class="muted" style="max-width: 62ch;">
        AI companies often face unexpected payment issues as they scale — especially when the use case does not fit
        traditional underwriting models.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Sudden account shutdowns</h3>
          <p class="muted">
            Platforms like Stripe and PayPal may flag AI businesses due to unclear use cases or policy concerns.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Gray-area risk classification</h3>
          <p class="muted">
            AI tools tied to automation, scraping, content generation, or niche use cases can trigger high-risk flags.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Subscription and usage billing complexity</h3>
          <p class="muted">
            Recurring billing, token-based usage, or API billing can create compliance and risk challenges if not
            documented clearly.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Scaling triggers risk</h3>
          <p class="muted">
            Rapid growth can lead processors to impose limits, reserves, or termination.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">International and high-volume issues</h3>
          <p class="muted">
            Global users and high transaction volume increase scrutiny and risk exposure.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built specifically for AI platforms and SaaS businesses</h2>
      <p class="muted" style="max-width: 62ch;">
        We understand how AI companies operate — and we build processing solutions that support innovation and scale.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">High-risk-friendly merchant accounts</h3>
          <p class="muted">
            We work with banks that understand SaaS, AI tools, and emerging tech business models.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Stable, long-term processing</h3>
          <p class="muted">
            Accounts structured for growth — not random shutdowns when volume spikes.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Subscription and usage-based billing support</h3>
          <p class="muted">
            Built for SaaS platforms, API billing, and recurring revenue models.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Flexible risk structuring</h3>
          <p class="muted">
            We help position your business clearly for underwriting — so banks see the story, not just the category.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Chargeback mitigation tools</h3>
          <p class="muted">
            Monitoring and dispute prevention so chargebacks do not define your profile overnight.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Multi-MID and backup processing</h3>
          <p class="muted">
            Redundancy where underwriting allows — uptime as you scale.
          </p>
        </div>
      </div>
      <p style="margin-top: 1.5rem;">
        <a class="btn btn--primary" href={applyHref}>Start your application</a>
      </p>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built for AI businesses like yours</h2>
      <p class="muted" style="max-width: 62ch;">We work with:</p>
      <ul style="margin: 1rem 0 0; padding-left: 1.25rem; max-width: 62ch;">
        <li>AI SaaS platforms</li>
        <li>Subscription-based AI tools</li>
        <li>API-based services (usage billing)</li>
        <li>Content generation platforms</li>
        <li>Automation and workflow tools</li>
        <li>Data scraping and analytics platforms</li>
        <li>Emerging or gray-area AI use cases</li>
      </ul>
      <p class="muted" style="margin-top: 1rem; max-width: 62ch;">
        Whether you run a SaaS dashboard, API, or checkout flow — we integrate with common stacks so operations stay
        yours while we align the merchant account.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Get approved in three simple steps</h2>
      <p class="muted" style="max-width: 62ch;">
        One application — clear underwriting — then launch.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">1</span>
          <h3 style="margin-top: 0;">Apply online</h3>
          <p class="muted">
            Tell us about your AI platform, billing model, and monthly volume.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">2</span>
          <h3 style="margin-top: 0;">Underwriting review</h3>
          <p class="muted">
            We match you with bank appetite for your business model and risk profile.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">3</span>
          <h3 style="margin-top: 0;">Get approved and start processing</h3>
          <p class="muted">
            Launch with a stable merchant account built for your platform — with clear monitoring and reserve
            expectations.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Trusted by high-growth tech and AI companies</h2>
      <p class="muted" style="max-width: 62ch;">
        Replace with real testimonials as soon as you have them.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">
            “We scaled our SaaS without worrying about payment shutdowns.”
          </p>
        </blockquote>
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">
            “Finally found a processor that understands AI platforms.”
          </p>
        </blockquote>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Everything you need to process AI payments</h2>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Subscription and usage-based billing support</h3>
          <p class="muted">Recurring and metered models with clear policies.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">SaaS and API integrations</h3>
          <p class="muted">Connect the stack you build on where partners allow.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Fraud and chargeback monitoring</h3>
          <p class="muted">Visibility before disputes become a termination event.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">High-volume scaling capability</h3>
          <p class="muted">Plan for growth with underwriting instead of surprise holds.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">International payment support</h3>
          <p class="muted">Global users where entity and bank setup align.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Secure payment gateways</h3>
          <p class="muted">Checkout flows aligned with how AI products are sold.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why AI companies choose Solvanta Pay</h2>
      <div class="grid-2" style="margin-top: 1.5rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Emerging tech and high-risk focus</h3>
          <p class="muted">We specialize in categories traditional processors misunderstand.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">SaaS and AI monetization fluency</h3>
          <p class="muted">Subscriptions, usage billing, and API economics — we speak your model.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Bank relationships others do not have</h3>
          <p class="muted">Partnerships for restricted and emerging verticals.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Scalable, long-term systems</h3>
          <p class="muted">Processing built to grow with your roadmap — not reset every quarter.</p>
        </div>
      </div>
      <div class="card" style="margin-top: 1.5rem;">
        <p class="muted" style="margin: 0; font-size: 1.05rem;">
          Most processors do not understand AI. We do.
        </p>
      </div>
    </div>
  </section>

  <div class="hub-cta-strip">
    <div class="hub-cta-strip__inner">
      <div>
        <h2 class="hub-cta-strip__title">Stop worrying about shutdowns. Start scaling your AI platform.</h2>
        <p class="muted" style="margin: 0; max-width: 48ch;">
          Get an AI-friendly merchant account designed for stability, flexibility, and growth. Apply now or call — we
          speak high-risk fluently.
        </p>
      </div>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center;">
        <a class="btn btn--primary" href={applyHref}>Apply now</a>
        <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
      </div>
    </div>
  </div>

  <section class="section section--tight">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">AI payment processing FAQ</h2>
      <div class="grid-2" style="margin-top: 1.25rem;">
        {faqCopy.map((item) => (
          <div class="card">
            <h3 style="font-size: 1.1rem; margin-top: 0;">{item.q}</h3>
            <p class="muted" style="margin-bottom: 0;">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  {
    relatedPosts.length > 0 && (
      <section class="section section--tight">
        <div class="container">
          <h2 style="margin-bottom: 1rem;">Related reading</h2>
          <ul style="list-style: none; padding: 0; margin: 0; display: grid; gap: 0.75rem;">
            {relatedPosts.map((post) => (
              <li>
                <a
                  href={`/blog/${post.id.replace(/\.md$/, "")}/`}
                  style="font-weight: 600; text-decoration: none;"
                >
                  {post.data.title}
                </a>
                <p class="muted" style="margin: 0.25rem 0 0; font-size: 0.95rem;">
                  {post.data.description}
                </p>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }
</BaseLayout>
