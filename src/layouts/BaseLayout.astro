---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieConsent from "../components/CookieConsent.astro";
import ClarityConsent from "../components/ClarityConsent";
import { getSiteUrl } from "../lib/site";

type Props = {
  title: string;
  description: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
};

const { title, description, jsonLd } = Astro.props;
const noIndex = import.meta.env.PUBLIC_NO_INDEX !== "false";
const site = getSiteUrl();
const canonicalUrl = new URL(Astro.url.pathname, site).href;
const ld = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-J1S4MXHCGC"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-J1S4MXHCGC');
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&family=Source+Sans+3:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      try {
        var _cc = localStorage.getItem("solvantapay_cookie_consent");
        if (_cc === "accepted" || _cc === "declined") {
          document.documentElement.classList.add("cookie-consent-resolved");
        }
      } catch (e) {}
    </script>
    {ld.map((obj) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <CookieConsent />
    <ClarityConsent client:load />
  </body>
</html>

