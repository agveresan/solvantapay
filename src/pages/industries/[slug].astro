---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getSiteUrl } from "../../lib/site";
import { INDUSTRIES, getIndustry, applyIndustryQueryValue } from "../../lib/industries";

export function getStaticPaths() {
  return INDUSTRIES.map((ind) => ({
    params: { slug: ind.slug },
  }));
}

const { slug } = Astro.params;
const industry = slug ? getIndustry(slug) : undefined;
if (!industry) {
  return Astro.redirect("/404");
}

const site = getSiteUrl();
const canonical = new URL(`/industries/${industry.slug}/`, site).href;
const applyHref = `/apply/?industry=${applyIndustryQueryValue(industry.title)}`;

const allPosts = await getCollection("blog");
const relatedPosts =
  industry.relatedBlogSlugs?.flatMap((s) => {
    const post = allPosts.find((e) => e.id.replace(/\.md$/, "") === s);
    return post ? [post] : [];
  }) ?? [];

const riskLabel = industry.risk === "low" ? "Low-risk vertical" : "High-risk vertical";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: `${industry.title} payment processing | Solvanta Pay`,
    description: industry.description,
    url: canonical,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
      { "@type": "ListItem", position: 2, name: "Industries", item: `${site}/industries/` },
      {
        "@type": "ListItem",
        position: 3,
        name: industry.title,
        item: canonical,
      },
    ],
  },
];
---
<BaseLayout
  title={`${industry.title} payment processing | Solvanta Pay`}
  description={industry.description}
  jsonLd={jsonLd}
>
  <section class="hero">
    <div class="container hero__grid">
      <div>
        <span class="pill">{riskLabel}</span>
        <h1 style="font-size: clamp(2rem, 4vw, 2.65rem); margin: 1rem 0 0.75rem;">
          {industry.title}
        </h1>
        <p class="muted" style="font-size: 1.1rem; max-width: 52ch;">
          {industry.tagline}
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem;">
          <a class="btn btn--primary" href={applyHref}>Start an application</a>
          <a class="btn btn--ghost" href="/industries/">All industries</a>
        </div>
      </div>
      <div class="card" style="align-self: start;">
        <div class="eyebrow">At a glance</div>
        <p style="margin: 0.75rem 0 0; font-size: 0.98rem;">
          {industry.description}
        </p>
        <p class="muted" style="margin: 1rem 0 0; font-size: 0.9rem;">
          Content on this site is informational and not legal advice. Underwriting determines final approval and
          pricing.
        </p>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <h2 style="margin-bottom: 0.75rem;">What makes this vertical sensitive</h2>
      <p class="muted" style="max-width: 62ch; margin-bottom: 1.25rem;">
        Issuers and bank partners look at chargebacks, fulfillment, and compliance differently in this space. Being
        explicit upfront helps applications move smoothly.
      </p>
      <ul style="margin: 0; padding-left: 1.25rem; max-width: 65ch;">
        {industry.painPoints.map((p) => (
          <li style="margin-bottom: 0.5rem;">{p}</li>
        ))}
      </ul>
      <p style="margin-top: 1.5rem;">
        <a class="btn btn--primary" href={applyHref}>Apply for this vertical</a>
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">How Solvanta Pay helps</h2>
      <p class="muted" style="max-width: 62ch;">
        Practical underwriting conversations and operational clarity — tuned to how you actually sell.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        {industry.valueProps.map((vp) => (
          <div class="card">
            <h3 style="margin-top: 0;">{vp.title}</h3>
            <p class="muted">{vp.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="hub-cta-strip">
    <div class="hub-cta-strip__inner">
      <div>
        <p style="font-family: var(--font-head); font-weight: 800; color: var(--color-primary); margin: 0 0 0.35rem;">
          Ready to talk terms?
        </p>
        <p class="muted" style="margin: 0;">
          Start the merchant application with your vertical prefilled — our team will follow up after review.
        </p>
      </div>
      <a class="btn btn--primary" href={applyHref} style="flex-shrink: 0;">Start an application</a>
    </div>
  </div>

  {
    relatedPosts.length > 0 && (
      <section class="section section--tight">
        <div class="container">
          <h2 style="margin-bottom: 1rem;">Related reading</h2>
          <ul style="list-style: none; padding: 0; margin: 0; display: grid; gap: 0.75rem;">
            {relatedPosts.map((post) => (
              <li>
                <a
                  href={`/blog/${post.id.replace(/\.md$/, "")}/`}
                  style="font-weight: 600; text-decoration: none;"
                >
                  {post.data.title}
                </a>
                <p class="muted" style="margin: 0.25rem 0 0; font-size: 0.95rem;">
                  {post.data.description}
                </p>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }
</BaseLayout>
