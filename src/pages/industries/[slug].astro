---
import { getCollection } from "astro:content";
import { getIndustry, INDUSTRIES } from "../../lib/industries";
import AccountingCpaFirms from "../../components/industries/long-form/accounting-cpa-firms.astro";
import AdultContent from "../../components/industries/long-form/adult-content.astro";
import Ai from "../../components/industries/long-form/ai.astro";
import BarRestaurant from "../../components/industries/long-form/bar-restaurant.astro";
import Cbd from "../../components/industries/long-form/cbd.astro";
import CreatorContent from "../../components/industries/long-form/creator-content.astro";
import CreditRepair from "../../components/industries/long-form/credit-repair.astro";
import Ecommerce from "../../components/industries/long-form/ecommerce.astro";
import FantasySports from "../../components/industries/long-form/fantasy-sports.astro";
import Firearms from "../../components/industries/long-form/firearms.astro";
import Healthcare from "../../components/industries/long-form/healthcare.astro";
import HomeServices from "../../components/industries/long-form/home-services.astro";
import LawFirms from "../../components/industries/long-form/law-firms.astro";
import Medspa from "../../components/industries/long-form/medspa.astro";
import Nutraceuticals from "../../components/industries/long-form/nutraceuticals.astro";
import OnlineDating from "../../components/industries/long-form/online-dating.astro";
import Peptide from "../../components/industries/long-form/peptide.astro";
import Retail from "../../components/industries/long-form/retail.astro";
import Saas from "../../components/industries/long-form/saas.astro";
import Telemedicine from "../../components/industries/long-form/telemedicine.astro";
import Travel from "../../components/industries/long-form/travel.astro";
import Vape from "../../components/industries/long-form/vape.astro";

const LONG_FORM_BY_SLUG = {
  ecommerce: Ecommerce,
  healthcare: Healthcare,
  "law-firms": LawFirms,
  medspa: Medspa,
  "bar-restaurant": BarRestaurant,
  retail: Retail,
  "home-services": HomeServices,
  "accounting-cpa-firms": AccountingCpaFirms,
  "creator-content": CreatorContent,
  ai: Ai,
  cbd: Cbd,
  "credit-repair": CreditRepair,
  "fantasy-sports": FantasySports,
  firearms: Firearms,
  "online-dating": OnlineDating,
  saas: Saas,
  telemedicine: Telemedicine,
  travel: Travel,
  vape: Vape,
  peptide: Peptide,
  nutraceuticals: Nutraceuticals,
  "adult-content": AdultContent,
} as const;

export function getStaticPaths() {
  return INDUSTRIES.map((ind) => ({
    params: { slug: ind.slug },
  }));
}

const { slug } = Astro.params;
const industry = slug ? getIndustry(slug) : undefined;
if (!industry) {
  return Astro.redirect("/404");
}

const Vertical = LONG_FORM_BY_SLUG[industry.slug as keyof typeof LONG_FORM_BY_SLUG];
if (!Vertical) {
  return Astro.redirect("/404");
}

const allPosts = await getCollection("blog");
const relatedPosts =
  industry.relatedBlogSlugs?.flatMap((s) => {
    const post = allPosts.find((e) => e.id.replace(/\.md$/, "") === s);
    return post ? [post] : [];
  }) ?? [];
---

<Vertical industry={industry} relatedPosts={relatedPosts} />
