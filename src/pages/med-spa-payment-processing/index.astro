---
import { Picture } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import heroVisual from "../../assets/images/hero-placeholder.png";
import { getSiteUrl } from "../../lib/site";

const site = getSiteUrl();
const salesTel = "+18556002419";
const canonical = new URL("/med-spa-payment-processing/", site).href;
const applyHref = `/apply/?industry=${encodeURIComponent("Med spa payment processing")}`;

const pageTitle = "Med spa payment processing | Solvanta Pay";
const pageDescription =
  "Medical spa merchant account and aesthetic clinic payment processing. Memberships, packages, Botox and filler payments — high-ticket med spa payment gateway with chargeback-aware support.";

const webPageLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonical,
};
const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
    {
      "@type": "ListItem",
      position: 2,
      name: "Med spa payment processing",
      item: canonical,
    },
  ],
};

const faqCopy = [
  {
    q: "Can med spas get approved for payment processing?",
    a: "Yes. We work with a wide range of med spas and aesthetic clinics — subject to underwriting, licensing where required, and bank partner appetite.",
  },
  {
    q: "Do you support memberships and packages?",
    a: "Yes. Monthly memberships, prepaid packages, and treatment plans are common — we help align billing cadence, refunds, and descriptors with what underwriters expect.",
  },
  {
    q: "Can I accept payments in-office and online?",
    a: "Yes. We support multiple payment methods and channels — card-present and card-not-present — where your gateway and bank stack allow.",
  },
  {
    q: "What about chargebacks?",
    a: "We provide monitoring, alerts, and dispute strategies suited to aesthetics — clear policies and client communication reduce avoidable disputes.",
  },
  {
    q: "How long does approval take?",
    a: "Many med spas see a decision within 24–72 hours when applications and documents are complete. Timing depends on underwriting and bank response times.",
  },
] as const;

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqCopy.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---
<BaseLayout title={pageTitle} description={pageDescription} jsonLd={[webPageLd, breadcrumbLd, faqLd]}>
  <section class="hero">
    <div class="container hero__grid">
      <div>
        <span class="pill">Aesthetics, injectables & wellness</span>
        <p class="eyebrow" style="margin: 0.75rem 0 0; font-size: 0.78rem;">
          Increase revenue with memberships, packages, and flexible payment options
        </p>
        <h1 style="font-size: clamp(2rem, 4vw, 2.85rem); margin: 0.5rem 0 1rem;">
          Med spa payment processing built for growth and client experience
        </h1>
        <p class="muted" style="font-size: 1.1rem; max-width: 52ch;">
          Running a med spa or aesthetic clinic? We provide secure, reliable payment processing designed for med spas,
          cosmetic treatments, and wellness clinics.
        </p>
        <p class="muted" style="font-size: 0.98rem; max-width: 52ch; margin-top: 0.75rem;">
          Create a seamless payment experience for your clients — from Botox and fillers to laser, skin care, and
          membership programs — without leaving revenue on the table.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem;">
          <a class="btn btn--primary" href={applyHref}>Get approved for med spa processing</a>
          <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
        </div>
        <ul class="trust-row trust-row--four" aria-label="Trust highlights">
          <li>Built for med spas and aesthetic clinics</li>
          <li>Memberships and package billing support</li>
          <li>In-person and online payments</li>
          <li>Fast approvals — often 24–72 hours when docs are complete</li>
        </ul>
      </div>
      <div class="hero__aside">
        <Picture
          src={heroVisual}
          alt="Abstract brand visual suggesting structured payment operations"
          widths={[400, 800, 1200]}
          sizes="(min-width: 900px) min(40vw, 540px), 100vw"
          formats={["avif", "webp"]}
          fallbackFormat="jpeg"
          quality={80}
          loading="eager"
          decoding="async"
          class="hero__visual"
        />
        <div class="card card--glass">
          <div class="eyebrow">Hybrid vertical</div>
          <ul style="margin: 1rem 0 0; padding-left: 1.1rem;">
            <li>High-ticket treatments — underwriting that understands premium aesthetics</li>
            <li>Memberships and prepaid packages — recurring and deferred revenue in one stack</li>
            <li>Chargeback awareness — common in aesthetics; we focus on monitoring and clear client expectations</li>
          </ul>
          <p class="muted" style="margin-top: 1rem; font-size: 0.95rem;">
            Clinical and marketing claims vary by jurisdiction. Content on this site is informational; approvals depend
            on underwriting and licensing where applicable.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why med spas struggle with payment processing</h2>
      <p class="muted" style="max-width: 62ch;">
        Med spas sit at the intersection of healthcare and retail — which makes payment processing more complex than
        most service businesses.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">High-ticket transactions</h3>
          <p class="muted">
            Treatments like Botox, fillers, and laser services involve large payments that can trigger processor
            scrutiny.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Chargebacks and disputes</h3>
          <p class="muted">
            Clients disputing results or expectations can increase chargeback risk.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Membership and package billing complexity</h3>
          <p class="muted">
            Recurring memberships and prepaid packages require flexible billing systems.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Outdated payment systems</h3>
          <p class="muted">
            Many clinics rely on manual or outdated systems that slow down operations.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Limited payment flexibility</h3>
          <p class="muted">
            Without modern payment options, clinics may lose revenue opportunities.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built specifically for med spas and aesthetic clinics</h2>
      <p class="muted" style="max-width: 62ch;">
        We provide payment solutions designed to support both the clinical and business sides of your med spa.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Secure, compliance-aware processing</h3>
          <p class="muted">
            Built for healthcare-adjacent businesses with a focus on security and reliability.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">High-ticket transaction support</h3>
          <p class="muted">
            Process large payments for premium treatments and services — within approved limits.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Membership and package billing support</h3>
          <p class="muted">
            Monthly memberships, prepaid packages, and treatment plans.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Improved client payment experience</h3>
          <p class="muted">
            Modern checkout, invoicing, and payment options.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Chargeback mitigation tools</h3>
          <p class="muted">
            Monitoring, alerts, and prevention strategies.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Scalable for growth</h3>
          <p class="muted">
            Expand services, locations, and revenue with processing that keeps pace.
          </p>
        </div>
      </div>
      <p style="margin-top: 1.5rem;">
        <a class="btn btn--primary" href={applyHref}>Start your application</a>
      </p>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built for med spas like yours</h2>
      <p class="muted" style="max-width: 62ch;">We work with:</p>
      <ul style="margin: 1rem 0 0; padding-left: 1.25rem; max-width: 62ch;">
        <li>Medical spas and aesthetic clinics</li>
        <li>Botox and injectable providers</li>
        <li>Laser treatment centers</li>
        <li>Skin care and anti-aging clinics</li>
        <li>Wellness and beauty clinics</li>
        <li>Membership-based med spas</li>
      </ul>
      <p class="muted" style="margin-top: 1rem; max-width: 62ch;">
        Whether you process in-office, online, or both — we can support your setup.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Get approved in three simple steps</h2>
      <p class="muted" style="max-width: 62ch;">
        One application — underwriting aligned to aesthetics and recurring revenue.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">1</span>
          <h3 style="margin-top: 0;">Apply online</h3>
          <p class="muted">
            Tell us about your med spa, services, and payment needs.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">2</span>
          <h3 style="margin-top: 0;">Underwriting review</h3>
          <p class="muted">
            We match you with the best solution for your business model.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">3</span>
          <h3 style="margin-top: 0;">Get approved and start processing</h3>
          <p class="muted">
            Launch with a reliable payment system built for your clinic.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Trusted by aesthetic and wellness clinics</h2>
      <p class="muted" style="max-width: 62ch;">
        Replace with real testimonials for stronger trust signals.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">
            &ldquo;We streamlined our payments and increased client conversions.&rdquo;
          </p>
        </blockquote>
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">
            &ldquo;Reliable processing for high-ticket services.&rdquo;
          </p>
        </blockquote>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Everything you need to process med spa payments</h2>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">In-person, online, and mobile payments</h3>
          <p class="muted">Meet clients at the front desk or on the web.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Membership and recurring billing support</h3>
          <p class="muted">Predictable MRR alongside treatment revenue.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Payment plans and package billing</h3>
          <p class="muted">Prepaid bundles and structured plans.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Fraud and chargeback monitoring</h3>
          <p class="muted">Visibility before disputes become a profile problem.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">High-ticket transaction support</h3>
          <p class="muted">Premium services without constant friction.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Integration-friendly solutions</h3>
          <p class="muted">Work with common clinic and booking tools where your stack allows.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why med spas choose Solvanta Pay</h2>
      <div class="grid-2" style="margin-top: 1.5rem;">
        <div class="card">
          <h3 style="margin-top: 0;">The med spa business model</h3>
          <p class="muted">Packages, memberships, and high-ticket treatment mixes.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Clinical and retail payment needs</h3>
          <p class="muted">One stack for services, upsells, and renewals.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Flexible, modern payment solutions</h3>
          <p class="muted">Channels and methods clients expect from premium brands.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Long-term systems for growing clinics</h3>
          <p class="muted">Processing that scales with new lines and locations.</p>
        </div>
      </div>
      <div class="card" style="margin-top: 1.5rem;">
        <p class="muted" style="margin: 0; font-size: 1.05rem;">
          Your payment system should enhance your client experience — not limit it.
        </p>
      </div>
    </div>
  </section>

  <div class="hub-cta-strip">
    <div class="hub-cta-strip__inner">
      <div>
        <h2 class="hub-cta-strip__title">Upgrade your payments. Elevate your client experience.</h2>
        <p class="muted" style="margin: 0; max-width: 48ch;">
          Get a med spa payment solution designed for growth, flexibility, and reliability.
        </p>
      </div>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center;">
        <a class="btn btn--primary" href={applyHref}>Apply now</a>
        <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
      </div>
    </div>
  </div>

  <section class="section section--tight">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Med spa payment processing FAQ</h2>
      <div class="grid-2" style="margin-top: 1.25rem;">
        {faqCopy.map((item) => (
          <div class="card">
            <h3 style="font-size: 1.1rem; margin-top: 0;">{item.q}</h3>
            <p class="muted" style="margin-bottom: 0;">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
