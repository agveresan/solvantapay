---
import { Picture } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import heroVisual from "../../assets/images/hero-placeholder.png";
import { getSiteUrl } from "../../lib/site";

const site = getSiteUrl();
const salesTel = "+18556002419";
const canonical = new URL("/retail-payment-processing/", site).href;
const applyHref = `/apply/?industry=${encodeURIComponent("Retail payment processing")}`;

const pageTitle = "Retail payment processing | Solvanta Pay";
const pageDescription =
  "Retail merchant account and POS payment processing for stores. Brick-and-mortar and hybrid retail — fast deposits, transparent pricing, in-store and online card acceptance.";

const webPageLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonical,
};
const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
    {
      "@type": "ListItem",
      position: 2,
      name: "Retail payment processing",
      item: canonical,
    },
  ],
};

const faqCopy = [
  {
    q: "Can retail stores get approved for payment processing?",
    a: "Yes. We work with a wide range of retail businesses — from small shops to large and multi-location operations — subject to underwriting and bank partner appetite.",
  },
  {
    q: "Do you integrate with POS systems?",
    a: "Yes. We support many leading retail POS systems and hardware — final pairing depends on your processor, gateway, and equipment choices.",
  },
  {
    q: "Can I accept payments both in-store and online?",
    a: "Yes. We help align card acceptance for physical retail and eCommerce — including hybrid brands — where your program supports it.",
  },
  {
    q: "How fast do I get my deposits?",
    a: "Funding speed depends on your processing program, batch timing, and bank partner. We focus on fast funding options where available and clear settlement expectations so you can manage inventory and cash flow.",
  },
  {
    q: "How long does approval take?",
    a: "Many retail businesses see a decision within 24–72 hours when applications and documents are complete. Timing depends on underwriting and bank response times.",
  },
] as const;

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqCopy.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---
<BaseLayout title={pageTitle} description={pageDescription} jsonLd={[webPageLd, breadcrumbLd, faqLd]}>
  <section class="hero">
    <div class="container hero__grid">
      <div>
        <span class="pill">Brick-and-mortar & hybrid retail</span>
        <p class="eyebrow" style="margin: 0.75rem 0 0; font-size: 0.78rem;">
          Lower your processing fees and improve your margins
        </p>
        <h1 style="font-size: clamp(2rem, 4vw, 2.85rem); margin: 0.5rem 0 1rem;">
          Retail payment processing built for speed, simplicity, and scale
        </h1>
        <p class="muted" style="font-size: 1.1rem; max-width: 52ch;">
          Running a retail store? We provide fast, reliable payment processing designed for retail businesses — from
          single locations to multi-store operations.
        </p>
        <p class="muted" style="font-size: 0.98rem; max-width: 52ch; margin-top: 0.75rem;">
          Faster checkout, better customer experience — with processing that scales as you add lanes, locations, or
          online revenue.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem;">
          <a class="btn btn--primary" href={applyHref}>Get approved for retail processing</a>
          <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
        </div>
        <ul class="trust-row trust-row--four" aria-label="Trust highlights">
          <li>Built for retail and brick-and-mortar stores</li>
          <li>Fast, reliable POS integrations</li>
          <li>In-store and online payment support</li>
          <li>Fast approvals — often 24–72 hours when docs are complete</li>
        </ul>
      </div>
      <div class="hero__aside">
        <Picture
          src={heroVisual}
          alt="Abstract brand visual suggesting structured payment operations"
          widths={[400, 800, 1200]}
          sizes="(min-width: 900px) min(40vw, 540px), 100vw"
          formats={["avif", "webp"]}
          fallbackFormat="jpeg"
          quality={80}
          loading="eager"
          decoding="async"
          class="hero__visual"
        />
        <div class="card card--glass">
          <div class="eyebrow">Operational focus</div>
          <ul style="margin: 1rem 0 0; padding-left: 1.1rem;">
            <li>Single store or many — underwriting that matches how you sell</li>
            <li>Cost control — transparent pricing so margin is not a mystery</li>
            <li>Cash flow — funding timelines you can plan around for inventory and payroll</li>
          </ul>
          <p class="muted" style="margin-top: 1rem; font-size: 0.95rem;">
            Rates, equipment, and settlement depend on your program. We align the stack to your lanes, channels, and
            volume — not a one-size-fits-all quote.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why retail businesses outgrow their payment processor</h2>
      <p class="muted" style="max-width: 62ch;">
        As your retail business grows, your payment system needs to keep up. Many retailers run into limitations that
        slow them down or cut into profits.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Slow checkout experiences</h3>
          <p class="muted">
            Lagging systems create long lines and frustrate customers.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">High processing fees</h3>
          <p class="muted">
            Even small percentage differences add up across high transaction volume.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Limited POS flexibility</h3>
          <p class="muted">
            Not every processor integrates cleanly with your retail setup or inventory tools.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Cash flow delays</h3>
          <p class="muted">
            Delayed deposits make it harder to manage inventory and operations.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Outdated payment technology</h3>
          <p class="muted">
            Older systems may not support contactless, mobile pay, or modern checkout flows.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built specifically for retail businesses</h2>
      <p class="muted" style="max-width: 62ch;">
        We provide payment solutions designed to improve efficiency, reduce costs, and support retail growth.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Fast, reliable transactions</h3>
          <p class="muted">
            Keep lines moving with seamless, high-speed payment processing.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">POS system compatibility</h3>
          <p class="muted">
            Integrate with leading retail POS systems and hardware — where your program supports it.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Competitive, transparent pricing</h3>
          <p class="muted">
            Reduce processing costs and protect your margins — with clear statements.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">In-store and online payments</h3>
          <p class="muted">
            Support physical retail and eCommerce in one coherent setup.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Fast funding and cash flow stability</h3>
          <p class="muted">
            Get deposits on a timeline you can plan against — for inventory and operations.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Scalable for growth</h3>
          <p class="muted">
            New locations, higher volume, or added channels — without reinventing processing every year.
          </p>
        </div>
      </div>
      <p style="margin-top: 1.5rem;">
        <a class="btn btn--primary" href={applyHref}>Start your application</a>
      </p>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built for retail businesses like yours</h2>
      <p class="muted" style="max-width: 62ch;">We work with:</p>
      <ul style="margin: 1rem 0 0; padding-left: 1.25rem; max-width: 62ch;">
        <li>Brick-and-mortar retail stores</li>
        <li>Multi-location retail businesses</li>
        <li>Boutiques and specialty shops</li>
        <li>Apparel and fashion retailers</li>
        <li>Electronics and tech stores</li>
        <li>Hybrid retail and eCommerce brands</li>
      </ul>
      <p class="muted" style="margin-top: 1rem; max-width: 62ch;">
        Whether you sell in-store, online, or both — we can support your setup.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Get approved in three simple steps</h2>
      <p class="muted" style="max-width: 62ch;">
        From application to first sale — built around your stores and channels.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">1</span>
          <h3 style="margin-top: 0;">Apply online</h3>
          <p class="muted">
            Tell us about your store, setup, and payment needs.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">2</span>
          <h3 style="margin-top: 0;">Setup and integration</h3>
          <p class="muted">
            We match you with the best POS and processing solution for your retail environment.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">3</span>
          <h3 style="margin-top: 0;">Start accepting payments</h3>
          <p class="muted">
            Launch with a fast, reliable system built for your retail business.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Trusted by retail businesses nationwide</h2>
      <p class="muted" style="max-width: 62ch;">
        Replace with real testimonials for stronger trust signals.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">
            &ldquo;Faster checkout and better reliability in-store.&rdquo;
          </p>
        </blockquote>
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">
            &ldquo;We reduced our processing costs and improved operations.&rdquo;
          </p>
        </blockquote>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Everything you need to process retail payments</h2>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">POS system integrations</h3>
          <p class="muted">Keep registers, back office, and payments aligned.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Contactless and mobile payments</h3>
          <p class="muted">Tap-to-pay and wallet experiences customers expect.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">In-store and online payment support</h3>
          <p class="muted">One story for omnichannel brands.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Fast deposit funding</h3>
          <p class="muted">Settlement options explained in plain terms.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Fraud and chargeback monitoring</h3>
          <p class="muted">Visibility when patterns shift by channel or SKU.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Inventory-friendly integrations</h3>
          <p class="muted">Work with retail stacks where your processor and POS allow.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why retail businesses choose Solvanta Pay</h2>
      <div class="grid-2" style="margin-top: 1.5rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Retail operations and workflows</h3>
          <p class="muted">Peaks, promotions, returns — we document how you actually run the floor.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Speed and reliability</h3>
          <p class="muted">Processing that keeps checkout out of the way of the sale.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Flexible, cost-effective solutions</h3>
          <p class="muted">Right-size pricing and equipment as you grow.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Long-term business growth</h3>
          <p class="muted">A partner for the second store, the new market, and higher volume.</p>
        </div>
      </div>
      <div class="card" style="margin-top: 1.5rem;">
        <p class="muted" style="margin: 0; font-size: 1.05rem;">
          Your payment system should make selling easier — not harder.
        </p>
      </div>
    </div>
  </section>

  <div class="hub-cta-strip">
    <div class="hub-cta-strip__inner">
      <div>
        <h2 class="hub-cta-strip__title">Simplify payments. Increase efficiency.</h2>
        <p class="muted" style="margin: 0; max-width: 48ch;">
          Upgrade to a payment solution built for retail speed, reliability, and growth.
        </p>
      </div>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center;">
        <a class="btn btn--primary" href={applyHref}>Apply now</a>
        <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
      </div>
    </div>
  </div>

  <section class="section section--tight">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Retail payment processing FAQ</h2>
      <div class="grid-2" style="margin-top: 1.25rem;">
        {faqCopy.map((item) => (
          <div class="card">
            <h3 style="font-size: 1.1rem; margin-top: 0;">{item.q}</h3>
            <p class="muted" style="margin-bottom: 0;">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
