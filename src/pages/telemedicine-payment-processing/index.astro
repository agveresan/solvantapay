---
import { Picture } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import heroVisual from "../../assets/images/hero-placeholder.png";
import { getSiteUrl } from "../../lib/site";

const site = getSiteUrl();
const salesTel = "+18556002419";
const canonical = new URL("/telemedicine-payment-processing/", site).href;
const applyHref = `/apply/?industry=${encodeURIComponent("Telemedicine payment processing")}`;

const pageTitle = "Telemedicine payment processing | Solvanta Pay";
const pageDescription =
  "Telehealth payment processing and healthcare merchant accounts for virtual care. Subscription billing, compliance-aware telemedicine payment gateway for digital health platforms.";

const webPageLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonical,
};
const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
    {
      "@type": "ListItem",
      position: 2,
      name: "Telemedicine payment processing",
      item: canonical,
    },
  ],
};

const faqCopy = [
  {
    q: "Can telemedicine businesses get approved for payment processing?",
    a: "Yes. Telemedicine is often treated as high-risk, but we work with banks that support telehealth and digital healthcare platforms — subject to underwriting, licensing, and bank partner appetite.",
  },
  {
    q: "Do you support subscription billing for telemedicine?",
    a: "Yes. Memberships, recurring care plans, and prescription-adjacent programs are common — we help align descriptors, cancellation paths, and billing cadence with what underwriters expect.",
  },
  {
    q: "What about compliance requirements?",
    a: "We help structure your processing setup to align with industry expectations for your model. Final requirements depend on your services, jurisdiction, and processor rules — we are not a law firm or HIPAA counsel.",
  },
  {
    q: "What if I have been declined before?",
    a: "That is common. Many telemedicine platforms come to us after being rejected by traditional processors. We map your services, billing model, and dispute history to the right underwriting conversation.",
  },
  {
    q: "How long does approval take?",
    a: "Many businesses see a decision within 24–72 hours when applications and documents are complete. Timing depends on underwriting and bank response times.",
  },
] as const;

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqCopy.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---
<BaseLayout title={pageTitle} description={pageDescription} jsonLd={[webPageLd, breadcrumbLd, faqLd]}>
  <section class="hero">
    <div class="container hero__grid">
      <div>
        <span class="pill">Telehealth, virtual care & digital health</span>
        <p class="eyebrow" style="margin: 0.75rem 0 0; font-size: 0.78rem;">
          Built for compliant telehealth platforms
        </p>
        <h1 style="font-size: clamp(2rem, 4vw, 2.85rem); margin: 0.5rem 0 1rem;">
          Telemedicine payment processing that scales with your practice
        </h1>
        <p class="muted" style="font-size: 1.1rem; max-width: 52ch;">
          Running a telehealth platform or online medical service? We provide secure, high-risk-friendly payment
          processing built for telemedicine, virtual care, and digital health businesses.
        </p>
        <p class="muted" style="font-size: 0.98rem; max-width: 52ch; margin-top: 0.75rem;">
          Reliable billing for ongoing patient care — subscriptions, memberships, and recurring models without the
          surprise shutdowns that hit fast-scaling telehealth stacks.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem;">
          <a class="btn btn--primary" href={applyHref}>Get approved for telemedicine processing</a>
          <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
        </div>
        <ul class="trust-row trust-row--four" aria-label="Trust highlights">
          <li>Built for telemedicine and digital health platforms</li>
          <li>Subscription and recurring billing support</li>
          <li>Compliance-aware processing solutions</li>
          <li>Fast approvals — often 24–72 hours when docs are complete</li>
        </ul>
      </div>
      <div class="hero__aside">
        <Picture
          src={heroVisual}
          alt="Abstract brand visual suggesting structured payment operations"
          widths={[400, 800, 1200]}
          sizes="(min-width: 900px) min(40vw, 540px), 100vw"
          formats={["avif", "webp"]}
          fallbackFormat="jpeg"
          quality={80}
          loading="eager"
          decoding="async"
          class="hero__visual"
        />
        <div class="card card--glass">
          <div class="eyebrow">At a glance</div>
          <ul style="margin: 1rem 0 0; padding-left: 1.1rem;">
            <li>Healthcare-adjacent underwriting — we document service and billing models clearly</li>
            <li>Subscription complexity — aligned descriptors for memberships and ongoing care</li>
            <li>Stability at scale — fewer avoidable limits as volume grows</li>
          </ul>
          <p class="muted" style="margin-top: 1rem; font-size: 0.95rem;">
            We are a payments partner, not legal or clinical counsel. HIPAA, licensing, and prescribing rules vary;
            approvals depend on underwriting.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why telemedicine businesses struggle to process payments</h2>
      <p class="muted" style="max-width: 62ch;">
        Telemedicine businesses operate in a highly regulated environment — making payment processing more complex than
        traditional businesses.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Healthcare plus high-risk classification</h3>
          <p class="muted">
            Telemedicine often gets flagged due to the combination of healthcare services and online delivery.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Subscription and billing complexity</h3>
          <p class="muted">
            Recurring billing for memberships, prescriptions, or ongoing care can trigger risk flags.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Compliance and regulatory concerns</h3>
          <p class="muted">
            Processors may hesitate due to patient data, prescriptions, and service claims.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Chargeback risk</h3>
          <p class="muted">
            Patients disputing consultations or outcomes can increase dispute rates.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Account instability during growth</h3>
          <p class="muted">
            As your platform scales, processors may impose reserves, limits, or shutdowns.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built specifically for telemedicine and digital health</h2>
      <p class="muted" style="max-width: 62ch;">
        We understand how telehealth businesses operate — and we build payment solutions designed for compliance,
        stability, and growth.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">High-risk-friendly merchant account approval</h3>
          <p class="muted">
            We work with banks that understand telemedicine and digital healthcare models.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Compliance-aware processing</h3>
          <p class="muted">
            We help structure your payment setup to align with regulatory expectations for your model.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Subscription and recurring billing support</h3>
          <p class="muted">
            Memberships, prescription programs, and ongoing care models — with clear policies.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Stable, long-term processing</h3>
          <p class="muted">
            Avoid sudden shutdowns with accounts designed for telehealth platforms.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Chargeback mitigation tools</h3>
          <p class="muted">
            Monitoring, alerts, and dispute prevention strategies.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Scalable infrastructure</h3>
          <p class="muted">
            Grow your platform without losing your payment processor — within approved limits.
          </p>
        </div>
      </div>
      <p style="margin-top: 1.5rem;">
        <a class="btn btn--primary" href={applyHref}>Start your application</a>
      </p>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built for telemedicine platforms like yours</h2>
      <p class="muted" style="max-width: 62ch;">We work with:</p>
      <ul style="margin: 1rem 0 0; padding-left: 1.25rem; max-width: 62ch;">
        <li>Telehealth platforms</li>
        <li>Online clinics and virtual care providers</li>
        <li>Prescription-based services</li>
        <li>Mental health and therapy platforms</li>
        <li>Subscription-based healthcare programs</li>
        <li>Wellness and digital health services</li>
      </ul>
      <p class="muted" style="margin-top: 1rem; max-width: 62ch;">
        Whether you offer consultations, memberships, or ongoing care — we can support your billing model.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Get approved in three simple steps</h2>
      <p class="muted" style="max-width: 62ch;">
        One application — telehealth-aware underwriting — then go live.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">1</span>
          <h3 style="margin-top: 0;">Apply online</h3>
          <p class="muted">
            Tell us about your telemedicine platform, services, and billing model.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">2</span>
          <h3 style="margin-top: 0;">Underwriting review</h3>
          <p class="muted">
            We match you with bank appetite for your compliance and risk profile.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">3</span>
          <h3 style="margin-top: 0;">Get approved and start processing</h3>
          <p class="muted">
            Launch with a stable merchant account built for your platform.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Trusted by digital health and telemedicine providers</h2>
      <p class="muted" style="max-width: 62ch;">
        Replace with real testimonials when available.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">
            &ldquo;We finally found a processor that understands telehealth.&rdquo;
          </p>
        </blockquote>
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">
            &ldquo;Reliable billing without worrying about shutdowns.&rdquo;
          </p>
        </blockquote>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Everything you need to process telemedicine payments</h2>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Subscription and recurring billing support</h3>
          <p class="muted">Care plans, memberships, and renewals.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Secure payment gateways</h3>
          <p class="muted">Checkout aligned with web and app experiences.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Fraud and chargeback monitoring</h3>
          <p class="muted">Visibility before disputes become a profile problem.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">High-volume scaling capability</h3>
          <p class="muted">Plan for growth with the right limits and redundancy.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">International payment support</h3>
          <p class="muted">Cross-border patients where your entity and stack allow.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Flexible integration options</h3>
          <p class="muted">Paths for common stacks and custom builds.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why telemedicine businesses choose Solvanta Pay</h2>
      <div class="grid-2" style="margin-top: 1.5rem;">
        <div class="card">
          <h3 style="margin-top: 0;">High-risk and regulated industries</h3>
          <p class="muted">We specialize in verticals generic processors mishandle.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Telehealth billing models</h3>
          <p class="muted">We understand subscriptions, consults, and hybrid care flows.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Bank relationships others do not have</h3>
          <p class="muted">Partnerships for healthcare-adjacent and digital health categories.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Scalable, long-term systems</h3>
          <p class="muted">Processing built for growth — not a disposable MID.</p>
        </div>
      </div>
      <div class="card" style="margin-top: 1.5rem;">
        <p class="muted" style="margin: 0; font-size: 1.05rem;">
          Most processors struggle with telemedicine. We&apos;re built for it.
        </p>
      </div>
    </div>
  </section>

  <div class="hub-cta-strip">
    <div class="hub-cta-strip__inner">
      <div>
        <h2 class="hub-cta-strip__title">Stop dealing with payment issues. Focus on patient care.</h2>
        <p class="muted" style="margin: 0; max-width: 48ch;">
          Get a telemedicine-friendly merchant account designed for compliance, stability, and growth.
        </p>
      </div>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center;">
        <a class="btn btn--primary" href={applyHref}>Apply now</a>
        <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
      </div>
    </div>
  </div>

  <section class="section section--tight">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Telemedicine payment processing FAQ</h2>
      <div class="grid-2" style="margin-top: 1.25rem;">
        {faqCopy.map((item) => (
          <div class="card">
            <h3 style="font-size: 1.1rem; margin-top: 0;">{item.q}</h3>
            <p class="muted" style="margin-bottom: 0;">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
