---
import { Picture } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import heroVisual from "../../assets/images/hero-placeholder.png";
import { getSiteUrl } from "../../lib/site";

const site = getSiteUrl();
const salesTel = "+18556002419";
const canonical = new URL("/law-firm-payment-processing/", site).href;
const applyHref = `/apply/?industry=${encodeURIComponent("Law firm payment processing")}`;

const pageTitle = "Law firm payment processing | Solvanta Pay";
const pageDescription =
  "Legal payment processing and attorney merchant accounts for law firms. Secure solutions for retainers, payment plans, and client collections — compliance-aware onboarding for legal professionals.";

const webPageLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonical,
};
const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
    {
      "@type": "ListItem",
      position: 2,
      name: "Law firm payment processing",
      item: canonical,
    },
  ],
};

const faqCopy = [
  {
    q: "Can law firms get approved for payment processing?",
    a: "Yes. We work with a wide range of legal professionals and practices — subject to underwriting, practice structure, and bank partner appetite.",
  },
  {
    q: "Do you support trust accounts and retainers?",
    a: "We provide merchant account and card acceptance options suited to common legal billing flows. IOLTA and trust-account rules vary by jurisdiction; how client funds are received, recorded, and reconciled must align with your ethical obligations — often with guidance from your ethics counsel. We focus on the payments layer and help you document flows for underwriting.",
  },
  {
    q: "Can I accept payments online and in-office?",
    a: "Yes. We support multiple payment methods and channels — card-present and card-not-present — where your gateway and bank stack allow.",
  },
  {
    q: "Do you support payment plans?",
    a: "Yes. Installment schedules and flexible payment options are supported — with clear authorization and disclosure aligned with your practice policies and processor requirements.",
  },
  {
    q: "How long does approval take?",
    a: "Many law firms see a decision within 24–72 hours when applications and documents are complete. Timing depends on underwriting and bank response times.",
  },
] as const;

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqCopy.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---
<BaseLayout title={pageTitle} description={pageDescription} jsonLd={[webPageLd, breadcrumbLd, faqLd]}>
  <section class="hero">
    <div class="container hero__grid">
      <div>
        <span class="pill">Attorneys, firms & legal practices</span>
        <p class="eyebrow" style="margin: 0.75rem 0 0; font-size: 0.78rem;">
          Secure, compliant payment solutions for legal professionals
        </p>
        <h1 style="font-size: clamp(2rem, 4vw, 2.85rem); margin: 0.5rem 0 1rem;">
          Law firm payment processing built for trust and reliability
        </h1>
        <p class="muted" style="font-size: 1.1rem; max-width: 52ch;">
          Running a law firm or legal practice? We provide secure, reliable payment processing designed for attorneys,
          law firms, and legal professionals.
        </p>
        <p class="muted" style="font-size: 0.98rem; max-width: 52ch; margin-top: 0.75rem;">
          Get paid faster with modern legal billing tools — invoicing, payment links, and flexible options that reduce
          friction for clients while keeping underwriting and security expectations in view.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem;">
          <a class="btn btn--primary" href={applyHref}>Get approved for law firm processing</a>
          <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
        </div>
        <ul class="trust-row trust-row--four" aria-label="Trust highlights">
          <li>Built for law firms and legal professionals</li>
          <li>Secure, compliance-aware processing</li>
          <li>Retainers and payment plan support</li>
          <li>Fast approvals — often 24–72 hours when docs are complete</li>
        </ul>
      </div>
      <div class="hero__aside">
        <Picture
          src={heroVisual}
          alt="Abstract brand visual suggesting structured payment operations"
          widths={[400, 800, 1200]}
          sizes="(min-width: 900px) min(40vw, 540px), 100vw"
          formats={["avif", "webp"]}
          fallbackFormat="jpeg"
          quality={80}
          loading="eager"
          decoding="async"
          class="hero__visual"
        />
        <div class="card card--glass">
          <div class="eyebrow">Professional services lens</div>
          <ul style="margin: 1rem 0 0; padding-left: 1.1rem;">
            <li>
              <strong>IOLTA awareness:</strong> Client funds and trust accounting are governed by state rules — we discuss
              how card acceptance fits your workflow; ethical structuring remains with your firm and counsel.
            </li>
            <li>Reliable collection — fewer avoidable delays from outdated payment rails</li>
            <li>Retainers, plans, and hourly or contingency models — documented clearly for underwriting</li>
          </ul>
          <p class="muted" style="margin-top: 1rem; font-size: 0.95rem;">
            Solvanta Pay provides merchant services, not legal ethics advice. Nothing on this page substitutes for
            guidance from your jurisdiction&apos;s rules or your professional advisors.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why law firms struggle with payment processing</h2>
      <p class="muted" style="max-width: 62ch;">
        Legal practices require a high level of trust, accuracy, and compliance — which makes payment processing more
        complex than in many industries.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Trust account (IOLTA) requirements</h3>
          <p class="muted">
            Handling client funds separately requires careful structuring of how and where payments are received and
            recorded.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Manual and delayed payments</h3>
          <p class="muted">
            Invoices, checks, and manual billing slow collections and cash flow.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Limited payment flexibility</h3>
          <p class="muted">
            Many firms lack modern payment options that clients expect.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Compliance and security concerns</h3>
          <p class="muted">
            Legal professionals must ensure client payment data is handled with appropriate safeguards.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Outdated systems</h3>
          <p class="muted">
            Legacy billing and payment tools create inefficiencies and missed opportunities.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built specifically for law firms and legal practices</h2>
      <p class="muted" style="max-width: 62ch;">
        We provide payment solutions designed for modern law firms — balancing compliance discipline, operational
        efficiency, and client convenience.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Secure, compliance-aware processing</h3>
          <p class="muted">
            Payment systems structured to support legal industry expectations — within processor and card network rules.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Retainer and trust-account support</h3>
          <p class="muted">
            Flexible options for common fee and client-fund flows — coordinated with how your firm reconciles and reports
            under applicable rules.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Payment plans and installments</h3>
          <p class="muted">
            Offer clients structured payment options to improve collections while documenting authorization clearly.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Faster, more reliable payments</h3>
          <p class="muted">
            Reduce delays with modern invoicing, payment links, and card acceptance.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Online and in-person payments</h3>
          <p class="muted">
            Accept payments in-office, online, or via mobile — where your stack supports it.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Scalable for growing firms</h3>
          <p class="muted">
            Support higher case volume and headcount without outgrowing your processor overnight.
          </p>
        </div>
      </div>
      <p style="margin-top: 1.5rem;">
        <a class="btn btn--primary" href={applyHref}>Start your application</a>
      </p>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built for law firms like yours</h2>
      <p class="muted" style="max-width: 62ch;">We work with:</p>
      <ul style="margin: 1rem 0 0; padding-left: 1.25rem; max-width: 62ch;">
        <li>Solo attorneys</li>
        <li>Small to mid-size law firms</li>
        <li>Personal injury firms</li>
        <li>Family law practices</li>
        <li>Criminal defense attorneys</li>
        <li>Corporate and business law firms</li>
      </ul>
      <p class="muted" style="margin-top: 1rem; max-width: 62ch;">
        Whether you bill retainers, hourly services, or contingency-based work — we can align payment acceptance with
        your firm&apos;s documented model.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Get approved in three simple steps</h2>
      <p class="muted" style="max-width: 62ch;">
        One application — underwriting aligned to professional services and legal billing.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">1</span>
          <h3 style="margin-top: 0;">Apply online</h3>
          <p class="muted">
            Tell us about your firm, billing structure, and payment needs.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">2</span>
          <h3 style="margin-top: 0;">Underwriting review</h3>
          <p class="muted">
            We match you with the best solution for your practice.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">3</span>
          <h3 style="margin-top: 0;">Get approved and start processing</h3>
          <p class="muted">
            Launch with a reliable payment system built for your firm.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Trusted by legal professionals</h2>
      <p class="muted" style="max-width: 62ch;">
        Replace with real testimonials for stronger credibility.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">
            &ldquo;We improved collections and simplified our billing process.&rdquo;
          </p>
        </blockquote>
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">
            &ldquo;Secure and reliable payment processing for our firm.&rdquo;
          </p>
        </blockquote>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Everything you need to process legal payments</h2>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Secure payment processing</h3>
          <p class="muted">Card acceptance with clear security expectations.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Online invoicing and payment links</h3>
          <p class="muted">Faster payment without unnecessary back-and-forth.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Retainer and trust-account support</h3>
          <p class="muted">Flows discussed in context of your reconciliation process.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Payment plans and installment options</h3>
          <p class="muted">Structured schedules with proper authorization.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">In-office and remote payment capabilities</h3>
          <p class="muted">Meet clients where they pay.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Integration-friendly solutions</h3>
          <p class="muted">Work with common practice tools where your stack allows.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why law firms choose Solvanta Pay</h2>
      <div class="grid-2" style="margin-top: 1.5rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Legal billing and trust considerations</h3>
          <p class="muted">We ask the right questions about retainers, fees, and how you handle client funds.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Security and reliability</h3>
          <p class="muted">Stable processing relationships suited to professional services.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Flexible payment solutions</h3>
          <p class="muted">Modern options without sacrificing clarity for finance and compliance teams.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Long-term systems for growing firms</h3>
          <p class="muted">Accounts structured to support practice growth — not a short-term fix.</p>
        </div>
      </div>
      <div class="card" style="margin-top: 1.5rem;">
        <p class="muted" style="margin: 0; font-size: 1.05rem;">
          Your payment system should enhance your practice — not complicate it.
        </p>
      </div>
    </div>
  </section>

  <div class="hub-cta-strip">
    <div class="hub-cta-strip__inner">
      <div>
        <h2 class="hub-cta-strip__title">Get paid faster. Simplify your practice.</h2>
        <p class="muted" style="margin: 0; max-width: 48ch;">
          Get a law firm payment solution designed for trust, compliance, and efficiency.
        </p>
      </div>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center;">
        <a class="btn btn--primary" href={applyHref}>Apply now</a>
        <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
      </div>
    </div>
  </div>

  <section class="section section--tight">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Law firm payment processing FAQ</h2>
      <div class="grid-2" style="margin-top: 1.25rem;">
        {faqCopy.map((item) => (
          <div class="card">
            <h3 style="font-size: 1.1rem; margin-top: 0;">{item.q}</h3>
            <p class="muted" style="margin-bottom: 0;">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
