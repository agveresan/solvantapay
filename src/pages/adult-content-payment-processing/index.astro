---
import { Picture } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import heroVisual from "../../assets/images/hero-placeholder.png";
import { getSiteUrl } from "../../lib/site";

const site = getSiteUrl();
const salesTel = "+18556002419";
const canonical = new URL("/adult-content-payment-processing/", site).href;
const applyHref = `/apply/?industry=${encodeURIComponent("Adult payment processing")}`;

const pageTitle = "Adult payment processing | Solvanta Pay";
const pageDescription =
  "Adult merchant accounts and high-risk adult payment processing. Adult payment gateway placement, subscription billing, discreet support — payment processing for adult websites and platforms.";

const webPageLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonical,
};
const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
    {
      "@type": "ListItem",
      position: 2,
      name: "Adult payment processing",
      item: canonical,
    },
  ],
};

const faqCopy = [
  {
    q: "Can adult businesses get approved for payment processing?",
    a: "Yes. Adult is high-risk, but we work with banks and processors that accept adult-friendly merchant models. Final approval depends on underwriting, documentation, and bank partner appetite.",
  },
  {
    q: "What types of adult businesses do you support?",
    a: "We support a wide range of models — including content platforms, subscriptions, e-commerce, and related services — subject to underwriting and compliance review for your specific offer.",
  },
  {
    q: "Do you support recurring billing?",
    a: "Yes. Subscription and membership models are supported with clear billing descriptors and cancellation paths that match issuer expectations.",
  },
  {
    q: "What if I've been shut down before?",
    a: "That is very common. Many of our clients come to us after being dropped by traditional processors. We map your platform and volume to the right underwriting conversation.",
  },
  {
    q: "How long does approval take?",
    a: "Many adult businesses see a decision within 24–72 hours when applications and documents are complete. Timing depends on underwriting and bank response times.",
  },
] as const;

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqCopy.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---
<BaseLayout title={pageTitle} description={pageDescription} jsonLd={[webPageLd, breadcrumbLd, faqLd]}>
  <section class="hero">
    <div class="container hero__grid">
      <div>
        <span class="pill">Adult & high-risk</span>
        <h1 style="font-size: clamp(2rem, 4vw, 2.85rem); margin: 1rem 0;">
          Adult payment processing that actually gets approved
        </h1>
        <p class="muted" style="font-size: 1.1rem; max-width: 52ch;">
          Tired of getting shut down for operating an adult business? We provide stable, high-risk merchant accounts
          built specifically for adult content, services, and platforms.
        </p>
        <p class="muted" style="font-size: 0.98rem; max-width: 52ch; margin-top: 0.75rem;">
          Professional, discreet support — stability and privacy first, no judgment — just clear underwriting.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem;">
          <a class="btn btn--primary" href={applyHref}>Get approved for adult processing</a>
          <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
        </div>
        <p class="muted" style="font-size: 0.92rem; font-weight: 600; margin: 1rem 0 0;">
          Recently shut down? We can help — tell us what happened in your application.
        </p>
        <ul class="trust-row trust-row--four" aria-label="Trust highlights">
          <li>Built for adult and high-risk businesses</li>
          <li>Content-friendly payment solutions</li>
          <li>Subscription and recurring billing support</li>
          <li>Fast approvals — often 24–72 hours when docs are complete</li>
        </ul>
      </div>
      <div class="hero__aside">
        <Picture
          src={heroVisual}
          alt="Abstract brand visual suggesting structured payment operations"
          widths={[400, 800, 1200]}
          sizes="(min-width: 900px) min(40vw, 540px), 100vw"
          formats={["avif", "webp"]}
          fallbackFormat="jpeg"
          quality={80}
          loading="eager"
          decoding="async"
          class="hero__visual"
        />
        <div class="card card--glass">
          <div class="eyebrow">At a glance</div>
          <ul style="margin: 1rem 0 0; padding-left: 1.1rem;">
            <li>Adult-friendly bank and gateway conversations</li>
            <li>Discreet, operator-focused follow-up</li>
            <li>Backup and multi-MID strategies where underwriting allows</li>
          </ul>
          <p class="muted" style="margin-top: 1rem; font-size: 0.95rem;">
            Content on this site is informational and not legal advice. Underwriting determines final approval and
            pricing.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why adult businesses struggle to process payments</h2>
      <p class="muted" style="max-width: 62ch;">
        The adult industry faces some of the strictest restrictions in payment processing — making stability hard with
        traditional providers.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Instant account shutdowns</h3>
          <p class="muted">
            Platforms like Stripe, PayPal, and Square do not support adult content — leading to immediate bans or sudden
            terminations.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Prohibited business classification</h3>
          <p class="muted">
            Many banks categorize adult businesses as restricted or prohibited, which limits your options upfront.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">High chargeback rates</h3>
          <p class="muted">
            Subscription models and digital content can drive disputes — and elevated risk flags.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Limited payment options</h3>
          <p class="muted">
            Many adult businesses are pushed into unreliable or low-quality processing solutions.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Scaling becomes riskier</h3>
          <p class="muted">
            As revenue grows, scrutiny increases — often resulting in shutdowns or higher reserves.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built specifically for adult businesses</h2>
      <p class="muted" style="max-width: 62ch;">
        We specialize in high-risk industries like adult — and we build processing systems designed for stability and
        scale.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">High-risk merchant account approval</h3>
          <p class="muted">
            We work with banks and processors that accept adult content and services — when underwriting aligns.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Content-friendly processing</h3>
          <p class="muted">
            Solutions aimed at adult platforms, subscriptions, and digital content delivery.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Subscription and recurring billing support</h3>
          <p class="muted">
            Built for membership sites, fan platforms, and ongoing services.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Chargeback mitigation tools</h3>
          <p class="muted">
            Monitoring, alerts, and prevention strategies so disputes do not define your profile overnight.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Offshore and domestic options</h3>
          <p class="muted">
            Flexible setups depending on your business model and risk level.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Multi-MID and backup processing</h3>
          <p class="muted">
            Layered solutions where underwriting allows — so you are not dependent on a single MID.
          </p>
        </div>
      </div>
      <p style="margin-top: 1.5rem;">
        <a class="btn btn--primary" href={applyHref}>Start your application</a>
      </p>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built for adult businesses like yours</h2>
      <p class="muted" style="max-width: 62ch;">We work with:</p>
      <ul style="margin: 1rem 0 0; padding-left: 1.25rem; max-width: 62ch;">
        <li>Adult content platforms</li>
        <li>Subscription-based adult sites</li>
        <li>Fan-based platforms and creators</li>
        <li>Adult e-commerce stores</li>
        <li>Webcam and live streaming services</li>
        <li>Dating and adult social platforms</li>
      </ul>
      <p class="muted" style="margin-top: 1rem; max-width: 62ch;">
        Whether you run a membership site, custom platform, or checkout — we integrate with common stacks so operations
        stay yours while we align the merchant account.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Get approved in three simple steps</h2>
      <p class="muted" style="max-width: 62ch;">
        Apply once — we handle the underwriting dialogue discreetly and efficiently.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">1</span>
          <h3 style="margin-top: 0;">Apply online</h3>
          <p class="muted">
            Tell us about your adult business, platform, and monthly volume.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">2</span>
          <h3 style="margin-top: 0;">Underwriting review</h3>
          <p class="muted">
            We match you with adult-friendly bank and gateway options based on your risk profile.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">3</span>
          <h3 style="margin-top: 0;">Get approved and start processing</h3>
          <p class="muted">
            Launch with a stable merchant account built for your business — with clear monitoring expectations.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Trusted by high-risk adult businesses</h2>
      <p class="muted" style="max-width: 62ch;">
        Replace with real testimonials when you can — this vertical depends heavily on trust.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">
            “We finally found a processor that supports our platform long-term.”
          </p>
        </blockquote>
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">“No more shutdowns or payment disruptions.”</p>
        </blockquote>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Everything you need to process adult payments</h2>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Subscription and recurring billing support</h3>
          <p class="muted">Memberships and renewals with clear billing policies.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Adult-friendly payment gateways</h3>
          <p class="muted">Gateway placement aligned with how adult businesses sell online.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Fraud and chargeback monitoring</h3>
          <p class="muted">Visibility before disputes become a profile problem.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">High-volume scaling capability</h3>
          <p class="muted">Plan for growth with underwriting instead of surprise holds.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">International payment support</h3>
          <p class="muted">Cross-border selling where your entity and bank stack support it.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Secure and discreet checkout solutions</h3>
          <p class="muted">Checkout experiences that respect privacy and stability.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why adult businesses choose Solvanta Pay</h2>
      <div class="grid-2" style="margin-top: 1.5rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Adult and high-risk specialization</h3>
          <p class="muted">We focus on categories mass-market processors reject.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Content and compliance awareness</h3>
          <p class="muted">We understand restrictions and what issuers ask about in underwriting.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Bank relationships others do not have</h3>
          <p class="muted">Partnerships built for restricted verticals.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Scalable, long-term systems</h3>
          <p class="muted">Processing meant to grow with you — not expire at the next review.</p>
        </div>
      </div>
      <div class="card" style="margin-top: 1.5rem;">
        <p class="muted" style="margin: 0; font-size: 1.05rem;">
          Most processors reject adult businesses. We are built for them.
        </p>
      </div>
    </div>
  </section>

  <div class="hub-cta-strip">
    <div class="hub-cta-strip__inner">
      <div>
        <h2 class="hub-cta-strip__title">Stop getting shut down. Start processing today.</h2>
        <p class="muted" style="margin: 0; max-width: 48ch;">
          Get an adult-friendly merchant account designed for stability, privacy, and growth. Apply now or call — we
          speak high-risk fluently.
        </p>
      </div>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center;">
        <a class="btn btn--primary" href={applyHref}>Apply now</a>
        <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
      </div>
    </div>
  </div>

  <section class="section section--tight">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Adult payment processing FAQ</h2>
      <div class="grid-2" style="margin-top: 1.25rem;">
        {faqCopy.map((item) => (
          <div class="card">
            <h3 style="font-size: 1.1rem; margin-top: 0;">{item.q}</h3>
            <p class="muted" style="margin-bottom: 0;">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
