---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { getSiteUrl } from "../../lib/site";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const site = getSiteUrl();
const slug = post.id.replace(/\.md$/, "");
const canonical = `${site}/blog/${slug}/`;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  author: { "@type": "Organization", name: "Solvanta Pay" },
  mainEntityOfPage: canonical,
};
---
<BaseLayout title={`${post.data.title} | Solvanta Pay`} description={post.data.description} jsonLd={jsonLd}>
  <article class="section">
    <div class="container prose">
      <p class="muted" style="margin-top: 0;">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
        </time>
      </p>
      <h1>{post.data.title}</h1>
      <Content />
      <p style="margin-top: 2rem;">
        <a href="/apply/" class="btn btn--primary">Apply</a>
        <a href="/blog/" class="btn btn--ghost" style="margin-left: 0.5rem;">All insights</a>
      </p>
    </div>
  </article>
</BaseLayout>

