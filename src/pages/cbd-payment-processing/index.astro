---
import { Picture } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import heroVisual from "../../assets/images/hero-placeholder.png";
import { getSiteUrl } from "../../lib/site";

const site = getSiteUrl();
const salesTel = "+18556002419";
const canonical = new URL("/cbd-payment-processing/", site).href;
const applyHref = `/apply/?industry=${encodeURIComponent("CBD payment processing")}`;

const pageTitle = "CBD payment processing | Solvanta Pay";
const pageDescription =
  "CBD merchant accounts and payment processing for hemp and wellness brands. THC-compliant placement, COA-friendly onboarding, domestic and offshore options — CBD payment gateway and high-risk CBD processing.";

const webPageLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonical,
};
const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
    {
      "@type": "ListItem",
      position: 2,
      name: "CBD payment processing",
      item: canonical,
    },
  ],
};

const faqCopy = [
  {
    q: "Can I get approved for CBD payment processing?",
    a: "Yes. When your products meet compliance expectations — THC limits, proper labeling, and documentation like COAs where required — approval is often achievable. Final decisions depend on underwriting and bank partner appetite.",
  },
  {
    q: "What documents do I need?",
    a: "Typically you will need COAs (lab reports), clear product details, website compliance (disclosures, age or jurisdiction messaging as applicable), and standard business documentation. Exact requests vary by partner.",
  },
  {
    q: "Do you support THC products?",
    a: "We primarily support hemp-derived CBD within legal THC thresholds. Some product mixes and jurisdictions may require a specialist conversation — talk to us about your catalog and we will map it to the right underwriting path.",
  },
  {
    q: "How long does approval take?",
    a: "Many CBD merchants see a decision within 24–72 hours when applications and documents are complete. Timing depends on underwriting and bank response times.",
  },
  {
    q: "Do you integrate with Shopify or WooCommerce?",
    a: "Yes. We support major e-commerce platforms including Shopify and WooCommerce, plus custom checkouts — so you can keep your storefront while we align the merchant account.",
  },
] as const;

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqCopy.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---
<BaseLayout title={pageTitle} description={pageDescription} jsonLd={[webPageLd, breadcrumbLd, faqLd]}>
  <section class="hero">
    <div class="container hero__grid">
      <div>
        <span class="pill">CBD, hemp & wellness</span>
        <h1 style="font-size: clamp(2rem, 4vw, 2.85rem); margin: 1rem 0;">
          CBD payment processing that actually gets approved
        </h1>
        <p class="muted" style="font-size: 1.1rem; max-width: 52ch;">
          Struggling to find a reliable payment processor for your CBD business? We provide stable, compliant merchant
          accounts built specifically for CBD, hemp, and wellness brands.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem;">
          <a class="btn btn--primary" href={applyHref}>Get approved for CBD processing</a>
          <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
        </div>
        <ul class="trust-row trust-row--four" aria-label="Trust highlights">
          <li>Approved for CBD and hemp businesses</li>
          <li>THC-compliant processing solutions</li>
          <li>Offshore and domestic merchant accounts</li>
          <li>Fast approvals — often 24–72 hours when docs are complete</li>
        </ul>
      </div>
      <div class="hero__aside">
        <Picture
          src={heroVisual}
          alt="Abstract brand visual suggesting structured payment operations"
          widths={[400, 800, 1200]}
          sizes="(min-width: 900px) min(40vw, 540px), 100vw"
          formats={["avif", "webp"]}
          fallbackFormat="jpeg"
          quality={80}
          loading="eager"
          decoding="async"
          class="hero__visual"
        />
        <div class="card card--glass">
          <div class="eyebrow">At a glance</div>
          <ul style="margin: 1rem 0 0; padding-left: 1.1rem;">
            <li>Bank partners open to CBD and hemp verticals</li>
            <li>Support for COAs, labeling, and site disclosure expectations</li>
            <li>Chargeback-aware e-commerce and subscription models</li>
          </ul>
          <p class="muted" style="margin-top: 1rem; font-size: 0.95rem;">
            Content on this site is informational and not legal advice. Underwriting determines final approval and
            pricing.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why CBD businesses struggle to process payments</h2>
      <p class="muted" style="max-width: 62ch;">
        Even though CBD is legal in many markets, payment processing is still one of the biggest obstacles to scaling your
        business.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">High-risk classification</h3>
          <p class="muted">
            Banks and processors still categorize CBD as high-risk because of regulatory complexity and policy changes.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Constant account shutdowns</h3>
          <p class="muted">
            Many CBD businesses get approved — only to be shut down weeks later by Stripe, Square, or PayPal when risk
            reviews catch up.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Compliance requirements (THC, COAs, labeling)</h3>
          <p class="muted">
            Processors expect documentation like lab reports (COAs), THC thresholds, and proper disclaimers — generic
            onboarding rarely prepares you for it.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Funds held or delayed</h3>
          <p class="muted">
            Payouts can be delayed or frozen due to perceived risk or compliance questions mid-flight.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Limited scaling options</h3>
          <p class="muted">
            As volume grows, many processors increase reserves or terminate accounts instead of growing with you.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built specifically for CBD and hemp businesses</h2>
      <p class="muted" style="max-width: 62ch;">
        We understand the compliance and risk landscape of CBD — and we build processing solutions around it.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">High-risk CBD merchant account approval</h3>
          <p class="muted">
            We work with banks that are comfortable with CBD and hemp products, improving your path to approval when
            underwriting aligns.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Compliance-friendly processing</h3>
          <p class="muted">
            We help you align with key expectations like THC limits, COAs, and proper website disclosures — so underwriting
            sees a coherent story.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Stable, long-term accounts</h3>
          <p class="muted">
            Solutions aimed at durable processing relationships — not a quick approval that disappears at the first
            review.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Offshore and domestic options</h3>
          <p class="muted">
            Flexible setups depending on your business model, volume, and risk profile.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Chargeback mitigation tools</h3>
          <p class="muted">
            Monitoring and strategies tailored to CBD e-commerce — so disputes do not define your account overnight.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Scalable infrastructure</h3>
          <p class="muted">
            Grow your CBD brand with a processing plan that anticipates volume — not one that panics after a spike.
          </p>
        </div>
      </div>
      <p style="margin-top: 1.5rem;">
        <a class="btn btn--primary" href={applyHref}>Start your application</a>
      </p>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built for CBD brands like yours</h2>
      <p class="muted" style="max-width: 62ch;">We work with:</p>
      <ul style="margin: 1rem 0 0; padding-left: 1.25rem; max-width: 62ch;">
        <li>CBD oil and tincture brands</li>
        <li>CBD gummies and edibles</li>
        <li>Topicals and skincare products</li>
        <li>Pet CBD products</li>
        <li>Subscription-based CBD programs</li>
        <li>High-volume e-commerce stores</li>
      </ul>
      <p class="muted" style="margin-top: 1rem; max-width: 62ch;">
        Whether you sell on Shopify, WooCommerce, or a custom funnel — we integrate with common stacks so you keep your
        storefront while we align the merchant account.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Get approved in three simple steps</h2>
      <p class="muted" style="max-width: 62ch;">
        Quick application, CBD-aware underwriting, then go live.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">1</span>
          <h3 style="margin-top: 0;">Apply online</h3>
          <p class="muted">
            Tell us about your CBD products, monthly volume, and current processor so we can map the right conversation.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">2</span>
          <h3 style="margin-top: 0;">Underwriting review</h3>
          <p class="muted">
            We match you with CBD-friendly bank and gateway options based on your risk profile and documentation.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">3</span>
          <h3 style="margin-top: 0;">Get approved and start processing</h3>
          <p class="muted">
            Launch with a stable merchant account built for your CBD business — with clear expectations on monitoring and
            reserves.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Trusted by high-risk CBD businesses</h2>
      <p class="muted" style="max-width: 62ch;">
        Replace with named testimonials when you have them — real quotes lift conversions significantly in CBD.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">
            “We finally found a processor that understands CBD compliance.”
          </p>
        </blockquote>
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">“Fast approval and no more payout delays.”</p>
        </blockquote>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Everything you need to process CBD payments confidently</h2>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">CBD-compliant payment gateways</h3>
          <p class="muted">Gateway placement that matches how CBD is sold online.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Recurring billing support</h3>
          <p class="muted">Subscriptions and repeat buyers with clear billing descriptors.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Fraud and chargeback monitoring</h3>
          <p class="muted">Visibility into disputes before they become a profile problem.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">International payment support</h3>
          <p class="muted">Cross-border selling where your entity and bank stack support it.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">High-volume scaling capabilities</h3>
          <p class="muted">Plan for growth instead of surprise holds after a sales spike.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Secure checkout integrations</h3>
          <p class="muted">Checkout flows that work with your platform and compliance story.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why CBD businesses choose Solvanta Pay</h2>
      <div class="grid-2" style="margin-top: 1.5rem;">
        <div class="card">
          <h3 style="margin-top: 0;">CBD and high-risk focus</h3>
          <p class="muted">We specialize in CBD and high-risk industries — not as a generic add-on.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Compliance fluency</h3>
          <p class="muted">
            We understand what issuers ask about COAs, THC limits, labeling, and site disclosures.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Bank relationships others do not have</h3>
          <p class="muted">Partnerships built for categories mass-market processors avoid.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Long-term, scalable systems</h3>
          <p class="muted">Processing architecture meant to grow with your brand — not expire at the next review.</p>
        </div>
      </div>
      <div class="card" style="margin-top: 1.5rem;">
        <p class="muted" style="margin: 0; font-size: 1.05rem;">
          Most processors hesitate with CBD. We are built for it.
        </p>
      </div>
    </div>
  </section>

  <div class="hub-cta-strip">
    <div class="hub-cta-strip__inner">
      <div>
        <h2 class="hub-cta-strip__title">Stop getting shut down. Start processing today.</h2>
        <p class="muted" style="margin: 0; max-width: 48ch;">
          Get a CBD-friendly merchant account designed for compliance, stability, and growth. Apply now or call — we
          speak high-risk fluently.
        </p>
      </div>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center;">
        <a class="btn btn--primary" href={applyHref}>Apply now</a>
        <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
      </div>
    </div>
  </div>

  <section class="section section--tight">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">CBD payment processing FAQ</h2>
      <div class="grid-2" style="margin-top: 1.25rem;">
        {faqCopy.map((item) => (
          <div class="card">
            <h3 style="font-size: 1.1rem; margin-top: 0;">{item.q}</h3>
            <p class="muted" style="margin-bottom: 0;">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
