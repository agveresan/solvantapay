---
import { Picture } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import heroVisual from "../../assets/images/hero-placeholder.png";
import { getSiteUrl } from "../../lib/site";

const site = getSiteUrl();
const salesTel = "+18556002419";
const canonical = new URL("/peptide-payment-processing/", site).href;
const applyHref = `/apply/?industry=${encodeURIComponent("Peptide payment processing")}`;

const pageTitle = "Peptide payment processing | Solvanta Pay";
const pageDescription =
  "Payment processing for peptides and research chemicals. High-risk merchant accounts, domestic and offshore options, chargeback-aware support — approval in as little as 24–72 hours for qualified applications.";

const webPageLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonical,
};
const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
    {
      "@type": "ListItem",
      position: 2,
      name: "Peptide payment processing",
      item: canonical,
    },
  ],
};

const faqCopy = [
  {
    q: "Can I get approved if I've been shut down before?",
    a: "Yes. Many of our clients come to us after being dropped by Stripe, PayPal, Square, or other processors. We work with banks that understand peptide and research-chemical models — final approval still depends on underwriting and documentation.",
  },
  {
    q: "Do you work with offshore peptide businesses?",
    a: "Yes. We offer both domestic and offshore solutions depending on your entity structure, compliance profile, and scaling goals. The right placement is determined during application review.",
  },
  {
    q: "How long does approval take?",
    a: "Typically 24–72 hours for many applications, depending on your business complexity and how complete your documentation is. Underwriting and bank partner timing can vary.",
  },
  {
    q: "What if I have high chargebacks?",
    a: "We can still help in many cases. We provide chargeback monitoring, mitigation strategies, and clear expectations on reserves. Severe ratios may require a documented improvement plan — underwriting sets final terms.",
  },
  {
    q: "Do you integrate with Shopify or custom checkouts?",
    a: "Yes. We support a wide range of gateways and integrations, including Shopify and custom stacks — so you can keep your funnel or storefront while we handle the merchant account side.",
  },
  {
    q: "What are your fees for peptide processing?",
    a: "Pricing depends on vertical, volume, processing history, and risk. We share indicative ranges when appropriate; final rates are confirmed after underwriting and are not guaranteed by anything on this page.",
  },
] as const;

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqCopy.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---
<BaseLayout title={pageTitle} description={pageDescription} jsonLd={[webPageLd, breadcrumbLd, faqLd]}>
  <section class="hero">
    <div class="container hero__grid">
      <div>
        <span class="pill">Peptide & research chemicals</span>
        <h1 style="font-size: clamp(2rem, 4vw, 2.85rem); margin: 1rem 0;">
          Peptide payment processing that actually gets approved
        </h1>
        <p class="muted" style="font-size: 1.1rem; max-width: 52ch;">
          Tired of getting shut down for selling research peptides? We provide stable, high-risk merchant accounts
          built specifically for peptide and research chemical businesses — not one-size-fits-all low-risk stacks.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem;">
          <a class="btn btn--primary" href={applyHref}>Get approved for peptide processing</a>
          <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
        </div>
        <ul class="trust-row trust-row--four" aria-label="Trust highlights">
          <li>Approved for peptide and research chemical sellers</li>
          <li>Offshore and domestic merchant accounts</li>
          <li>Chargeback-aware solutions</li>
          <li>Fast approvals — often 24–72 hours when docs are complete</li>
        </ul>
      </div>
      <div class="hero__aside">
        <Picture
          src={heroVisual}
          alt="Abstract brand visual suggesting structured payment operations"
          widths={[400, 800, 1200]}
          sizes="(min-width: 900px) min(40vw, 540px), 100vw"
          formats={["avif", "webp"]}
          fallbackFormat="jpeg"
          quality={80}
          loading="eager"
          decoding="async"
          class="hero__visual"
        />
        <div class="card card--glass">
          <div class="eyebrow">At a glance</div>
          <ul style="margin: 1rem 0 0; padding-left: 1.1rem;">
            <li>High-risk placement built for restricted product categories</li>
            <li>Underwriting that understands subscription and recurring models</li>
            <li>Backup and multi-MID strategies where underwriting allows</li>
          </ul>
          <p class="muted" style="margin-top: 1rem; font-size: 0.95rem;">
            Content on this site is informational and not legal advice. Underwriting determines final approval and
            pricing.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why peptide businesses struggle to process payments</h2>
      <p class="muted" style="max-width: 62ch;">
        If you sell peptides or research chemicals, you have probably already seen how hard it is to keep a processor.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Instant account shutdowns</h3>
          <p class="muted">
            Platforms like Stripe, PayPal, and Square flag peptide businesses almost immediately — often freezing funds
            without warning.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Restricted product classification</h3>
          <p class="muted">
            Even when labeled for research use only, peptides are often treated as high-risk or prohibited by generic
            processors.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Funds held or frozen</h3>
          <p class="muted">
            Payouts can sit in review for weeks or months when compliance teams do not understand your model.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">High chargeback risk</h3>
          <p class="muted">
            Subscriptions, recurring orders, or buyer misunderstanding can spike disputes — and one bad month can trigger
            termination.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">No long-term stability</h3>
          <p class="muted">
            Even when you get approved, many providers eventually shut you down once volume grows and risk reviews
            intensify.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built specifically for peptide and research chemical merchants</h2>
      <p class="muted" style="max-width: 62ch;">
        We do not force peptide businesses into low-risk systems — we build processing around how you actually sell.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">High-risk merchant account approval</h3>
          <p class="muted">
            We work with banks that understand peptide businesses and can move you forward — even if you have been
            declined before.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Stable processing infrastructure</h3>
          <p class="muted">
            Accounts structured for durability: clear monitoring expectations instead of surprise shutdowns when volume
            ticks up.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Offshore and domestic options</h3>
          <p class="muted">
            Flexible setups based on your business model, risk profile, and how you plan to scale.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Chargeback mitigation tools</h3>
          <p class="muted">
            Alerts, monitoring, and prevention strategies so you can respond before disputes define your profile.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Multi-MID and backup solutions</h3>
          <p class="muted">
            Redundancy where underwriting allows — so you are not left without processing after a single flag.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Underwriting you can actually talk to</h3>
          <p class="muted">
            Direct dialogue on reserves, monitoring, and documentation — so you are not guessing what the bank wants.
          </p>
        </div>
      </div>
      <p style="margin-top: 1.5rem;">
        <a class="btn btn--primary" href={applyHref}>Start your application</a>
      </p>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built for peptide sellers like you</h2>
      <p class="muted" style="max-width: 62ch;">We work with businesses selling:</p>
      <ul style="margin: 1rem 0 0; padding-left: 1.25rem; max-width: 62ch;">
        <li>Research peptides</li>
        <li>SARMs and adjacent products</li>
        <li>Research chemicals</li>
        <li>Lab-use compounds</li>
        <li>Subscription-based peptide programs</li>
      </ul>
      <p class="muted" style="margin-top: 1rem; max-width: 62ch;">
        Whether you run Shopify, a custom checkout, or a funnel — we can integrate with common stacks so operations stay
        yours while we handle the merchant account.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Get approved in three simple steps</h2>
      <p class="muted" style="max-width: 62ch;">
        Quick form, clear underwriting, then launch — we keep the process moving.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">1</span>
          <h3 style="margin-top: 0;">Apply online</h3>
          <p class="muted">
            Tell us about your peptide business, volume, chargeback history, and current processing setup.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">2</span>
          <h3 style="margin-top: 0;">Underwriting review</h3>
          <p class="muted">
            We match you with bank appetite for your risk profile and document anything issuers will want to see upfront.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">3</span>
          <h3 style="margin-top: 0;">Get approved and start processing</h3>
          <p class="muted">
            Go live with a stable merchant account built for peptide sales — not a disposable MID that disappears at the
            first review.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Trusted by high-risk businesses nationwide</h2>
      <p class="muted" style="max-width: 62ch;">
        Swap in named testimonials when you have them. The lines below are illustrative examples of the outcomes we
        optimize for.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">
            “After getting shut down twice, we were finally able to scale with Solvanta Pay.”
          </p>
        </blockquote>
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">“Fast approval and no more payout holds.”</p>
        </blockquote>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Everything you need to process peptide payments confidently</h2>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">High-risk payment gateway integrations</h3>
          <p class="muted">Connect the stack you already use where partners support it.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Recurring billing support</h3>
          <p class="muted">Subscriptions and repeat buyers with clear billing descriptors and policies.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Fraud and chargeback monitoring</h3>
          <p class="muted">Visibility and habits that keep ratios under control.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">International processing support</h3>
          <p class="muted">Cross-border selling when your entity and bank setup align.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">High-volume scaling</h3>
          <p class="muted">Plan for growth with underwriting instead of surprise holds after a spike.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Secure checkout solutions</h3>
          <p class="muted">Checkout experiences that match how peptide buyers actually purchase.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why peptide businesses choose Solvanta Pay</h2>
      <div class="grid-2" style="margin-top: 1.5rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Built for high-risk, not a side product</h3>
          <p class="muted">
            We specialize in high-risk industries like peptides — not as an afterthought.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Underwriting and compliance fluency</h3>
          <p class="muted">
            We understand underwriting and compliance conversations issuers actually care about.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Bank relationships others do not have</h3>
          <p class="muted">
            We maintain banking relationships built for categories generic processors avoid.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Long-term, scalable setups</h3>
          <p class="muted">
            We build long-term, scalable processing — not quick fixes that fail at volume.
          </p>
        </div>
      </div>
      <div class="card" style="margin-top: 1.5rem;">
        <p class="muted" style="margin: 0; font-size: 1.05rem;">
          Most processors avoid peptide businesses. We are built for them.
        </p>
      </div>
    </div>
  </section>

  <div class="hub-cta-strip">
    <div class="hub-cta-strip__inner">
      <div>
        <h2 class="hub-cta-strip__title">Stop getting shut down. Start processing today.</h2>
        <p class="muted" style="margin: 0; max-width: 48ch;">
          Get a peptide-friendly merchant account designed for stability and growth. Apply now or call — we speak
          high-risk fluently.
        </p>
      </div>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center;">
        <a class="btn btn--primary" href={applyHref}>Apply now</a>
        <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
      </div>
    </div>
  </div>

  <section class="section section--tight">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Peptide payment processing FAQ</h2>
      <div class="grid-2" style="margin-top: 1.25rem;">
        {faqCopy.map((item) => (
          <div class="card">
            <h3 style="font-size: 1.1rem; margin-top: 0;">{item.q}</h3>
            <p class="muted" style="margin-bottom: 0;">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
