---
import { Picture } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import heroVisual from "../../assets/images/hero-placeholder.png";
import { getSiteUrl } from "../../lib/site";

const site = getSiteUrl();
const salesTel = "+18556002419";
const canonical = new URL("/travel-payment-processing/", site).href;
const applyHref = `/apply/?industry=${encodeURIComponent("Travel payment processing")}`;

const pageTitle = "Travel payment processing | Solvanta Pay";
const pageDescription =
  "Travel merchant account and high-risk travel payment processing for agencies, tour operators, and booking platforms. Chargeback support, high-ticket bookings, cash flow-friendly setups.";

const webPageLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonical,
};
const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
    {
      "@type": "ListItem",
      position: 2,
      name: "Travel payment processing",
      item: canonical,
    },
  ],
};

const faqCopy = [
  {
    q: "Can travel businesses get approved for payment processing?",
    a: "Yes. Travel is high-risk for many banks, but we work with partners that specialize in travel, tourism, and booking businesses — subject to underwriting and bank appetite.",
  },
  {
    q: "Do you support high-ticket transactions?",
    a: "Yes. We focus on solutions designed for large booking amounts and multi-leg packages — final limits and pricing come from underwriting.",
  },
  {
    q: "What about chargebacks and cancellations?",
    a: "We provide monitoring, alerts, and dispute strategies aligned with travel booking patterns. Clear policies and customer communication reduce avoidable disputes.",
  },
  {
    q: "Will I have rolling reserves?",
    a: "It depends on your business profile and bank terms. We work to structure setups that balance risk with cash flow — reserves are not always avoidable, but they can often be optimized.",
  },
  {
    q: "How long does approval take?",
    a: "Many travel businesses see a decision within 24–72 hours when applications and documents are complete. Timing depends on underwriting and bank response times.",
  },
] as const;

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqCopy.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---
<BaseLayout title={pageTitle} description={pageDescription} jsonLd={[webPageLd, breadcrumbLd, faqLd]}>
  <section class="hero">
    <div class="container hero__grid">
      <div>
        <span class="pill">Agencies, tours & booking platforms</span>
        <p class="eyebrow" style="margin: 0.75rem 0 0; font-size: 0.78rem;">
          Tired of reserves killing your cash flow?
        </p>
        <h1 style="font-size: clamp(2rem, 4vw, 2.85rem); margin: 0.5rem 0 1rem;">
          Travel payment processing that keeps your bookings moving
        </h1>
        <p class="muted" style="font-size: 1.1rem; max-width: 52ch;">
          Running a travel business or booking platform? We provide stable, high-risk-friendly merchant accounts built for
          travel agencies, tour operators, and booking platforms.
        </p>
        <p class="muted" style="font-size: 0.98rem; max-width: 52ch; margin-top: 0.75rem;">
          Processing $50K+ in bookings monthly? We can support you — with underwriting that understands long lead times,
          peaks, and high-ticket sales.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem;">
          <a class="btn btn--primary" href={applyHref}>Get approved for travel processing</a>
          <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
        </div>
        <ul class="trust-row trust-row--four" aria-label="Trust highlights">
          <li>Built for travel and booking businesses</li>
          <li>High-ticket transaction support</li>
          <li>Chargeback mitigation solutions</li>
          <li>Fast approvals — often 24–72 hours when docs are complete</li>
        </ul>
      </div>
      <div class="hero__aside">
        <Picture
          src={heroVisual}
          alt="Abstract brand visual suggesting structured payment operations"
          widths={[400, 800, 1200]}
          sizes="(min-width: 900px) min(40vw, 540px), 100vw"
          formats={["avif", "webp"]}
          fallbackFormat="jpeg"
          quality={80}
          loading="eager"
          decoding="async"
          class="hero__visual"
        />
        <div class="card card--glass">
          <div class="eyebrow">At a glance</div>
          <ul style="margin: 1rem 0 0; padding-left: 1.1rem;">
            <li>Cash flow stability — structure reserves and holds with the full picture in view</li>
            <li>Chargeback protection — monitoring aligned with cancellations and disputes</li>
            <li>Peak-season reliability — multi-MID and backup where underwriting allows</li>
          </ul>
          <p class="muted" style="margin-top: 1rem; font-size: 0.95rem;">
            Approvals, reserves, and limits depend on underwriting. Content on this site is informational and not a
            guarantee of terms.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why travel businesses struggle to process payments</h2>
      <p class="muted" style="max-width: 62ch;">
        The travel industry is considered high-risk due to delayed fulfillment, cancellations, and high transaction
        values — making reliable processing difficult.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">High chargeback risk</h3>
          <p class="muted">
            Cancellations, disputes, and customer dissatisfaction can lead to elevated chargebacks.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Delayed fulfillment concerns</h3>
          <p class="muted">
            Trips are often booked months in advance, increasing risk for processors.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Large ticket sizes</h3>
          <p class="muted">
            High transaction amounts increase scrutiny and risk exposure.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Rolling reserves and cash holds</h3>
          <p class="muted">
            Many processors hold a percentage of revenue, restricting cash flow.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Account shutdowns during growth</h3>
          <p class="muted">
            As volume increases, processors may impose limits or terminate accounts.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built specifically for travel and booking businesses</h2>
      <p class="muted" style="max-width: 62ch;">
        We understand the operational and financial challenges of travel businesses — and we build processing solutions
        that support long-term growth.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">High-risk merchant account approval</h3>
          <p class="muted">
            We work with banks experienced in travel, tourism, and booking platforms.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">High-ticket transaction support</h3>
          <p class="muted">
            Process large bookings without constant flags or disruptions — within approved limits.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Stable, long-term processing</h3>
          <p class="muted">
            Avoid sudden shutdowns with accounts structured for your business model.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Reduced reserve structures (when possible)</h3>
          <p class="muted">
            We help optimize your setup to improve cash flow — subject to risk and bank policy.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Chargeback mitigation tools</h3>
          <p class="muted">
            Protect your business with monitoring, alerts, and prevention strategies.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Multi-MID and backup processing</h3>
          <p class="muted">
            Continuity during peak booking seasons and scaling periods — where underwriting allows.
          </p>
        </div>
      </div>
      <p style="margin-top: 1.5rem;">
        <a class="btn btn--primary" href={applyHref}>Start your application</a>
      </p>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built for travel businesses like yours</h2>
      <p class="muted" style="max-width: 62ch;">We work with:</p>
      <ul style="margin: 1rem 0 0; padding-left: 1.25rem; max-width: 62ch;">
        <li>Travel agencies</li>
        <li>Tour operators</li>
        <li>Vacation booking platforms</li>
        <li>Cruise and package providers</li>
        <li>Event and experience booking businesses</li>
        <li>Online travel marketplaces</li>
      </ul>
      <p class="muted" style="margin-top: 1rem; max-width: 62ch;">
        Whether you book online, over the phone, or through agents — we can support your setup and integrate with common
        gateways and booking flows.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Get approved in three simple steps</h2>
      <p class="muted" style="max-width: 62ch;">
        One application — travel-aware underwriting — then go live.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">1</span>
          <h3 style="margin-top: 0;">Apply online</h3>
          <p class="muted">
            Tell us about your travel business, booking model, and monthly volume.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">2</span>
          <h3 style="margin-top: 0;">Underwriting review</h3>
          <p class="muted">
            We match you with bank appetite for your risk profile.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">3</span>
          <h3 style="margin-top: 0;">Get approved and start processing</h3>
          <p class="muted">
            Launch with a stable merchant account built for your business.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Trusted by travel businesses nationwide</h2>
      <p class="muted" style="max-width: 62ch;">
        Replace with real testimonials when available — cash flow and uptime stories convert strongly here.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">
            &ldquo;We finally found a processor that supports our booking model.&rdquo;
          </p>
        </blockquote>
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">
            &ldquo;No more cash flow issues from reserves and holds.&rdquo;
          </p>
        </blockquote>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Everything you need to process travel payments</h2>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">High-ticket transaction support</h3>
          <p class="muted">Large packages and deposits with clear underwriting.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Online and phone booking integrations</h3>
          <p class="muted">Card-not-present and agent-assisted flows.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Fraud and chargeback monitoring</h3>
          <p class="muted">Visibility before disputes become a profile problem.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">High-volume scaling capability</h3>
          <p class="muted">Plan for peaks and campaigns with the right limits.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">International payment support</h3>
          <p class="muted">Global travelers where your entity and stack support it.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Secure payment gateways</h3>
          <p class="muted">Checkout aligned with web and call-center operations.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why travel businesses choose Solvanta Pay</h2>
      <div class="grid-2" style="margin-top: 1.5rem;">
        <div class="card">
          <h3 style="margin-top: 0;">High-risk industries like travel</h3>
          <p class="muted">We specialize in verticals generic processors mishandle.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Booking cycles and fulfillment timelines</h3>
          <p class="muted">Long lead times and cancellation patterns are part of the story.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Bank relationships others do not have</h3>
          <p class="muted">Partnerships for travel and booking categories.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Scalable, long-term systems</h3>
          <p class="muted">Processing built for growth — not a disposable MID.</p>
        </div>
      </div>
      <div class="card" style="margin-top: 1.5rem;">
        <p class="muted" style="margin: 0; font-size: 1.05rem;">
          Most processors struggle with travel. We&apos;re built for it.
        </p>
      </div>
    </div>
  </section>

  <div class="hub-cta-strip">
    <div class="hub-cta-strip__inner">
      <div>
        <h2 class="hub-cta-strip__title">Stop dealing with holds. Start scaling your bookings.</h2>
        <p class="muted" style="margin: 0; max-width: 48ch;">
          Get a travel-friendly merchant account designed for stability, cash flow, and growth. Keep your cash flowing —
          process large bookings confidently and avoid shutdowns during peak season.
        </p>
      </div>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center;">
        <a class="btn btn--primary" href={applyHref}>Apply now</a>
        <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
      </div>
    </div>
  </div>

  <section class="section section--tight">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Travel payment processing FAQ</h2>
      <div class="grid-2" style="margin-top: 1.25rem;">
        {faqCopy.map((item) => (
          <div class="card">
            <h3 style="font-size: 1.1rem; margin-top: 0;">{item.q}</h3>
            <p class="muted" style="margin-bottom: 0;">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
