---
import { Picture } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import heroVisual from "../../assets/images/hero-placeholder.png";
import { getSiteUrl } from "../../lib/site";

const site = getSiteUrl();
const salesTel = "+18556002419";
const canonical = new URL("/home-services-payment-processing/", site).href;
const applyHref = `/apply/?industry=${encodeURIComponent("Home services payment processing")}`;

const pageTitle = "Home services payment processing | Solvanta Pay";
const pageDescription =
  "Contractor payment processing and home service merchant accounts. Mobile payments, invoices, deposits, job billing — fast funding for HVAC, plumbing, landscaping, and local service businesses.";

const webPageLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonical,
};
const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
    {
      "@type": "ListItem",
      position: 2,
      name: "Home services payment processing",
      item: canonical,
    },
  ],
};

const faqCopy = [
  {
    q: "Can home service businesses get approved for payment processing?",
    a: "Yes. We work with a wide range of contractors and service providers — subject to underwriting and bank partner appetite.",
  },
  {
    q: "Can I accept payments on-site?",
    a: "Yes. Mobile and on-site acceptance from phones or tablets is core to how we structure programs — aligned with your gateway and equipment.",
  },
  {
    q: "Do you support invoices and payment links?",
    a: "Yes. Invoices and secure payment links help you collect between visits — with clear authorization and descriptors.",
  },
  {
    q: "Can I collect deposits?",
    a: "Yes. Upfront deposits and progress payments are supported — documented for underwriting so your job-based model is clear.",
  },
  {
    q: "How fast do I get paid?",
    a: "Funding speed depends on your processing program, batch timing, and bank partner. We focus on fast funding options where available and clear settlement expectations so cash flow matches how you run jobs.",
  },
] as const;

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqCopy.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---
<BaseLayout title={pageTitle} description={pageDescription} jsonLd={[webPageLd, breadcrumbLd, faqLd]}>
  <section class="hero">
    <div class="container hero__grid">
      <div>
        <span class="pill">Contractors & local service pros</span>
        <p class="eyebrow" style="margin: 0.75rem 0 0; font-size: 0.78rem;">
          Get paid the same day you finish the job — when your program and batch timing allow
        </p>
        <h1 style="font-size: clamp(2rem, 4vw, 2.85rem); margin: 0.5rem 0 1rem;">
          Home services payment processing built to get you paid faster
        </h1>
        <p class="muted" style="font-size: 1.1rem; max-width: 52ch;">
          Running a home service business? We provide fast, reliable payment processing designed for contractors, service
          pros, and local businesses.
        </p>
        <p class="muted" style="font-size: 0.98rem; max-width: 52ch; margin-top: 0.75rem;">
          No complicated systems — just get paid. Simple invoicing, mobile acceptance, and deposits that match how you
          work in the field.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem;">
          <a class="btn btn--primary" href={applyHref}>Get approved for home services processing</a>
          <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
        </div>
        <ul class="trust-row trust-row--four" aria-label="Trust highlights">
          <li>Built for home service businesses</li>
          <li>Mobile, invoicing, and on-site payment support</li>
          <li>Deposits and job-based billing</li>
          <li>Fast approvals — often 24–72 hours when docs are complete</li>
        </ul>
      </div>
      <div class="hero__aside">
        <Picture
          src={heroVisual}
          alt="Abstract brand visual suggesting structured payment operations"
          widths={[400, 800, 1200]}
          sizes="(min-width: 900px) min(40vw, 540px), 100vw"
          formats={["avif", "webp"]}
          fallbackFormat="jpeg"
          quality={80}
          loading="eager"
          decoding="async"
          class="hero__visual"
        />
        <div class="card card--glass">
          <div class="eyebrow">Cash flow first</div>
          <ul style="margin: 1rem 0 0; padding-left: 1.1rem;">
            <li>Money in hand sooner — funding timelines explained for your program</li>
            <li>Deposits and draws — match payments to milestones, not just the final invoice</li>
            <li>Reliability in the field — mobile-first, not office-heavy</li>
          </ul>
          <p class="muted" style="margin-top: 1rem; font-size: 0.95rem;">
            Same-day and next-day funding depend on processor rules, cutoffs, and bank posting — we set expectations in
            writing, not hype.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why home service businesses struggle with payments</h2>
      <p class="muted" style="max-width: 62ch;">
        In home services, cash flow is critical — and outdated payment systems can slow everything down.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Slow or delayed payments</h3>
          <p class="muted">
            Waiting on checks or invoices can delay cash flow and operations.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Limited payment options</h3>
          <p class="muted">
            Not offering modern payment methods can cost you jobs.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Manual invoicing and tracking</h3>
          <p class="muted">
            Paper invoices and manual systems create inefficiencies and missed payments.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Difficulty collecting deposits</h3>
          <p class="muted">
            Without easy payment options, securing upfront deposits becomes harder.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Poor on-site payment experience</h3>
          <p class="muted">
            You need a system that works in the field — not just in the office.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built specifically for home service businesses</h2>
      <p class="muted" style="max-width: 62ch;">
        We provide payment solutions designed to help you get paid faster, simplify operations, and grow your business.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Mobile and on-site payments</h3>
          <p class="muted">
            Accept payments directly from your phone or tablet while on the job.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Invoicing and payment links</h3>
          <p class="muted">
            Send invoices and get paid quickly with simple, secure payment links.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Deposit and progress payment support</h3>
          <p class="muted">
            Collect upfront deposits and milestone payments with clear documentation.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Fast funding and cash flow stability</h3>
          <p class="muted">
            Get your money on a predictable timeline so you can keep jobs moving.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Simple, reliable processing</h3>
          <p class="muted">
            No complicated systems — tools that work when you need them.
          </p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Scalable for growth</h3>
          <p class="muted">
            More crews, more trucks, more revenue — processing that scales with you.
          </p>
        </div>
      </div>
      <p style="margin-top: 1.5rem;">
        <a class="btn btn--primary" href={applyHref}>Start your application</a>
      </p>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Built for home service businesses like yours</h2>
      <p class="muted" style="max-width: 62ch;">We work with:</p>
      <ul style="margin: 1rem 0 0; padding-left: 1.25rem; max-width: 62ch;">
        <li>Landscaping companies</li>
        <li>Concrete contractors</li>
        <li>Roofing companies</li>
        <li>HVAC businesses</li>
        <li>Plumbing services</li>
        <li>Electrical contractors</li>
        <li>General contractors and remodelers</li>
      </ul>
      <p class="muted" style="margin-top: 1rem; max-width: 62ch;">
        Whether you collect on-site, online, or through invoices — we align processing to your workflow.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Get approved in three simple steps</h2>
      <p class="muted" style="max-width: 62ch;">
        From application to first deposit — built around crews and job sites.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">1</span>
          <h3 style="margin-top: 0;">Apply online</h3>
          <p class="muted">
            Tell us about your business, services, and payment needs.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">2</span>
          <h3 style="margin-top: 0;">Setup and integration</h3>
          <p class="muted">
            We match you with the best tools for your workflow.
          </p>
        </div>
        <div class="card step-card">
          <span class="step-card__num" aria-hidden="true">3</span>
          <h3 style="margin-top: 0;">Start getting paid faster</h3>
          <p class="muted">
            Launch with a payment system built for your business.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Trusted by contractors and service pros</h2>
      <p class="muted" style="max-width: 62ch;">
        Replace with real testimonials for strong local trust.
      </p>
      <div class="grid-3" style="margin-top: 2rem;">
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">
            &ldquo;We get paid faster and don&apos;t chase invoices anymore.&rdquo;
          </p>
        </blockquote>
        <blockquote class="card" style="margin: 0;">
          <p style="margin: 0; font-style: italic;">
            &ldquo;Simple system that works perfectly in the field.&rdquo;
          </p>
        </blockquote>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Everything you need to get paid</h2>
      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-top: 0;">Mobile payment processing</h3>
          <p class="muted">Card present when you are on the job.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Invoicing and payment links</h3>
          <p class="muted">Email or text a link — get paid without another trip.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Deposit and progress billing</h3>
          <p class="muted">Milestones that match real projects.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Fast deposit funding</h3>
          <p class="muted">Settlement options explained in plain language.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Fraud and chargeback monitoring</h3>
          <p class="muted">Visibility when patterns shift by job type or channel.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Easy-to-use tools</h3>
          <p class="muted">Less time on admin — more time on the work.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Why home service businesses choose Solvanta Pay</h2>
      <div class="grid-2" style="margin-top: 1.5rem;">
        <div class="card">
          <h3 style="margin-top: 0;">How service businesses operate</h3>
          <p class="muted">Crews, trucks, deposits, and callbacks — we get it.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Speed, simplicity, and reliability</h3>
          <p class="muted">Processing that does not get in the way of the next job.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Flexible payment options</h3>
          <p class="muted">On-site, online, and between visits — your call.</p>
        </div>
        <div class="card">
          <h3 style="margin-top: 0;">Get paid faster</h3>
          <p class="muted">Programs aligned with cash flow — not surprise holds.</p>
        </div>
      </div>
      <div class="card" style="margin-top: 1.5rem;">
        <p class="muted" style="margin: 0; font-size: 1.05rem;">
          Your payment system should work as hard as you do.
        </p>
      </div>
    </div>
  </section>

  <div class="hub-cta-strip">
    <div class="hub-cta-strip__inner">
      <div>
        <h2 class="hub-cta-strip__title">Stop chasing payments. Start getting paid faster.</h2>
        <p class="muted" style="margin: 0; max-width: 48ch;">
          Upgrade to a payment solution built for contractors and home service professionals.
        </p>
      </div>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center;">
        <a class="btn btn--primary" href={applyHref}>Apply now</a>
        <a class="btn btn--ghost" href={`tel:${salesTel}`}>Speak with a specialist</a>
      </div>
    </div>
  </div>

  <section class="section section--tight">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Home services payment processing FAQ</h2>
      <div class="grid-2" style="margin-top: 1.25rem;">
        {faqCopy.map((item) => (
          <div class="card">
            <h3 style="font-size: 1.1rem; margin-top: 0;">{item.q}</h3>
            <p class="muted" style="margin-bottom: 0;">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
