PUBLIC_SITE_URL=https://www.solvantapay.com

# Block search indexing while staging. Set to false for production launch.
PUBLIC_NO_INDEX=true
PUBLIC_APPLY_URL=http://localhost:3001/apply

# Microsoft Clarity project ID (defaults to production ID if unset). Set empty to disable Clarity.
PUBLIC_CLARITY_PROJECT_ID=w3jzgrtw97

# Apply API server (run: npm run api)
RESEND_API_KEY=
RESEND_FROM=onboarding@yourdomain.com
RESEND_TO=applications@yourdomain.com
ALLOWED_ORIGINS=http://localhost:4321,https://www.solvantapay.com
GHL_WEBHOOK_URL=
PORT=3001
